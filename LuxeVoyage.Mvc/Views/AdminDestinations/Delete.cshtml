@model LuxeVoyage.Mvc.Models.Destination
<div class="px-8 py-10 font-body-md max-w-xl">
<h1 class="font-h2 text-h2 text-slate-900 dark:text-white mb-4">Delete destination</h1>
<p class="text-slate-600 dark:text-slate-400 mb-6">Delete <strong>@Model.Title</strong>? This cannot be undone.</p>
<form asp-action="Delete" method="post">
@Html.AntiForgeryToken()
<input type="hidden" asp-for="Id" />
<button type="submit" class="rounded-lg bg-error text-white px-6 py-2 mr-4">Delete</button>
<a asp-action="Index" class="rounded-lg border px-6 py-2">Cancel</a>
</form>
</div>
