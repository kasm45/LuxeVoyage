@model LuxeVoyage.Mvc.Models.Destination
<div class="space-y-8 max-w-3xl">
<div asp-validation-summary="All" class="text-red-600 text-sm"></div>

<section class="space-y-4 border-b border-slate-200 dark:border-slate-700 pb-6">
<h2 class="font-h3 text-lg font-semibold text-slate-900 dark:text-white">Basics</h2>
<p class="text-sm text-slate-600 dark:text-slate-400">Canonical title and routing. Listing and detail pages can override display text in the sections below.</p>
<div>
<label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Title</label>
<input asp-for="Title" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 dark:border-slate-600" />
<span asp-validation-for="Title" class="text-red-600 text-xs"></span>
</div>
<div>
<label class="block text-sm font-medium text-slate-700 dark:text-slate-300">URL slug</label>
<input asp-for="Slug" placeholder="antalya-turkey" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 dark:border-slate-600 font-mono text-sm" />
<span class="text-xs text-slate-500 dark:text-slate-400">Lowercase letters, numbers, hyphens only (normalized on save).</span>
<span asp-validation-for="Slug" class="text-red-600 text-xs"></span>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
<div>
<label class="block text-sm font-medium">Category</label>
<select asp-for="Category" asp-items="Html.GetEnumSelectList<LuxeVoyage.Mvc.Models.ExperienceCategoryKind>()" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></select>
</div>
<div>
<label class="block text-sm font-medium">Region (filters)</label>
<select asp-for="Region" asp-items="Html.GetEnumSelectList<LuxeVoyage.Mvc.Models.RegionKind>()" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></select>
</div>
</div>
<label class="inline-flex items-center gap-2 cursor-pointer">
<input type="checkbox" asp-for="IsActive" class="rounded border-slate-400" />
<span class="text-sm text-slate-700 dark:text-slate-300">Active on public site</span>
</label>
</section>

<section class="space-y-4 border-b border-slate-200 dark:border-slate-700 pb-6">
<h2 class="font-h3 text-lg font-semibold text-slate-900 dark:text-white border-b border-slate-200 dark:border-slate-600 pb-2">Listing Page Settings</h2>
<p class="text-sm text-slate-600 dark:text-slate-400">Used only on <span class="font-mono">/destinations</span> cards.</p>
<label class="inline-flex items-center gap-2 cursor-pointer">
<input type="checkbox" asp-for="IsVisibleOnListing" class="rounded border-slate-400" />
<span class="text-sm text-slate-700 dark:text-slate-300">Show on destinations listing</span>
</label>
<div>
<label class="block text-sm font-medium">Card title</label>
<input asp-for="CardTitle" placeholder="Leave blank to use Basics title" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" />
</div>
<div>
<label class="block text-sm font-medium">Card summary</label>
<textarea asp-for="CardSummary" rows="3" placeholder="Leave blank to use legacy summary" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea>
</div>
<div>
<label class="block text-sm font-medium">Card image URL</label>
<input asp-for="CardImageUrl" class="js-lv-admin-img-src mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" data-lv-preview="lv-prev-card" />
<div class="mt-2"><img id="lv-prev-card" src="" alt="" class="hidden max-h-40 rounded-lg border border-slate-200 dark:border-slate-600 object-cover bg-slate-100 dark:bg-slate-800" /></div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
<div>
<label class="block text-sm font-medium">Card badge</label>
<input asp-for="CardBadge" placeholder="Leave blank for category label" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" />
</div>
<div>
<label class="block text-sm font-medium">Card region (display)</label>
<input asp-for="CardRegion" placeholder="Leave blank for region filter label" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" />
</div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
<div>
<label class="block text-sm font-medium">Card price hint</label>
<input asp-for="CardPriceHint" placeholder="Leave blank for legacy price hint" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" />
</div>
<div>
<label class="block text-sm font-medium">Card rating</label>
<input asp-for="CardRating" type="number" step="0.1" min="0" max="5" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" />
<span class="text-xs text-slate-500">Leave blank to use legacy rating.</span>
</div>
</div>
</section>

<section class="space-y-4 border-b border-slate-200 dark:border-slate-700 pb-6">
<h2 class="font-h3 text-lg font-semibold text-slate-900 dark:text-white border-b border-slate-200 dark:border-slate-600 pb-2">Destination Detail Page</h2>
<p class="text-sm text-slate-600 dark:text-slate-400">Used only on <span class="font-mono">/destinations/{slug}</span>.</p>
<div>
<label class="block text-sm font-medium">Hero title</label>
<input asp-for="HeroTitle" placeholder="Leave blank to use Basics title" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" />
</div>
<div>
<label class="block text-sm font-medium">Hero subtitle</label>
<input asp-for="HeroSubtitle" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" />
</div>
<div>
<label class="block text-sm font-medium">Detail description</label>
<textarea asp-for="DetailDescription" rows="10" placeholder="Leave blank to use legacy long description" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea>
</div>
<div>
<label class="block text-sm font-medium">Detail tagline (chips)</label>
<input asp-for="DetailTagline" placeholder="Leave blank for legacy tag line" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" />
</div>
</section>

<section class="space-y-4 border-b border-slate-200 dark:border-slate-700 pb-6">
<h2 class="font-h3 text-lg font-semibold text-slate-900 dark:text-white border-b border-slate-200 dark:border-slate-600 pb-2">Gallery Images</h2>
<p class="text-sm text-slate-600 dark:text-slate-400">Four independent URLs. Layout: large left (1), top-right (2), bottom-right left (3), bottom-right right (4). Empty slots are omitted on the public page.</p>
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
<div class="space-y-2">
<label class="block text-sm font-medium">Image 1 URL</label>
<input asp-for="GalleryImage1Url" class="js-lv-admin-img-src w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" data-lv-preview="lv-prev-g1" />
<div class="mt-1"><img id="lv-prev-g1" src="" alt="" class="hidden max-h-36 w-full rounded-lg border border-slate-200 dark:border-slate-600 object-cover bg-slate-100 dark:bg-slate-800" /></div>
</div>
<div class="space-y-2">
<label class="block text-sm font-medium">Image 2 URL</label>
<input asp-for="GalleryImage2Url" class="js-lv-admin-img-src w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" data-lv-preview="lv-prev-g2" />
<div class="mt-1"><img id="lv-prev-g2" src="" alt="" class="hidden max-h-36 w-full rounded-lg border border-slate-200 dark:border-slate-600 object-cover bg-slate-100 dark:bg-slate-800" /></div>
</div>
<div class="space-y-2">
<label class="block text-sm font-medium">Image 3 URL</label>
<input asp-for="GalleryImage3Url" class="js-lv-admin-img-src w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" data-lv-preview="lv-prev-g3" />
<div class="mt-1"><img id="lv-prev-g3" src="" alt="" class="hidden max-h-36 w-full rounded-lg border border-slate-200 dark:border-slate-600 object-cover bg-slate-100 dark:bg-slate-800" /></div>
</div>
<div class="space-y-2">
<label class="block text-sm font-medium">Image 4 URL</label>
<input asp-for="GalleryImage4Url" class="js-lv-admin-img-src w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" data-lv-preview="lv-prev-g4" />
<div class="mt-1"><img id="lv-prev-g4" src="" alt="" class="hidden max-h-36 w-full rounded-lg border border-slate-200 dark:border-slate-600 object-cover bg-slate-100 dark:bg-slate-800" /></div>
</div>
</div>
<p class="text-xs text-slate-500 dark:text-slate-400">Tip: legacy “Gallery image URLs” below still backfills empty slots until you replace them.</p>
</section>

<section class="space-y-4 border-b border-slate-200 dark:border-slate-700 pb-6">
<h2 class="font-h3 text-lg font-semibold text-slate-900 dark:text-white">Legacy &amp; fallback fields</h2>
<p class="text-sm text-slate-600 dark:text-slate-400">Kept for backward compatibility. New listing/detail fields above take precedence when set.</p>
<div>
<label class="block text-sm font-medium">Card / listing image URL (legacy)</label>
<input asp-for="ImageUrl" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" />
</div>
<div>
<label class="block text-sm font-medium">Short summary (legacy)</label>
<textarea asp-for="Summary" rows="3" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea>
</div>
<div>
<label class="block text-sm font-medium">Hero image URL (legacy)</label>
<input asp-for="HeroImageUrl" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" />
</div>
<div>
<label class="block text-sm font-medium">Gallery image URLs (legacy CSV)</label>
<textarea asp-for="GalleryImagesCsv" rows="4" placeholder="One URL per line or comma-separated" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm"></textarea>
</div>
<div>
<label class="block text-sm font-medium">Long description (legacy)</label>
<textarea asp-for="LongDescription" rows="8" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea>
</div>
<div>
<label class="block text-sm font-medium">Tag line (legacy)</label>
<input asp-for="TagLine" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" placeholder="e.g. Coastal or Coastal, Luxury" />
</div>
<div>
<label class="block text-sm font-medium">Map / location illustration URL</label>
<input asp-for="MapImageUrl" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" />
</div>
</section>

<section class="space-y-4 border-b border-slate-200 dark:border-slate-700 pb-6">
<h2 class="font-h3 text-lg font-semibold text-slate-900 dark:text-white">Copy &amp; breadcrumbs</h2>
<div>
<label class="block text-sm font-medium">Highlights &amp; included experiences</label>
<textarea asp-for="HighlightsCsv" rows="5" placeholder="One item per line or comma-separated" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
<div>
<label class="block text-sm font-medium">Breadcrumb region label</label>
<input asp-for="BreadcrumbRegion" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" />
</div>
<div>
<label class="block text-sm font-medium">Breadcrumb city / area</label>
<input asp-for="BreadcrumbCity" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" />
</div>
<div>
<label class="block text-sm font-medium">Breadcrumb current</label>
<input asp-for="BreadcrumbCurrent" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" />
</div>
</div>
<div>
<label class="block text-sm font-medium">Location label (header)</label>
<input asp-for="LocationLabel" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" />
</div>
<div>
<label class="block text-sm font-medium">Where you'll be (detail section)</label>
<textarea asp-for="WhereYoullBeText" rows="5" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea>
</div>
</section>

<section class="space-y-4 pb-6">
<h2 class="font-h3 text-lg font-semibold text-slate-900 dark:text-white">Planning hints</h2>
<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
<div>
<label class="block text-sm font-medium">Best time to visit</label>
<input asp-for="BestTimeToVisit" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" />
</div>
<div>
<label class="block text-sm font-medium">Weather / climate</label>
<input asp-for="WeatherClimate" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" />
</div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
<div>
<label class="block text-sm font-medium">Rating (legacy)</label>
<input asp-for="Rating" type="number" step="0.1" min="0" max="5" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" />
</div>
<div>
<label class="block text-sm font-medium">Price hint (legacy / booking panel)</label>
<input asp-for="PriceHint" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" placeholder="$290" />
</div>
</div>
</section>
</div>
<script>
document.querySelectorAll('.js-lv-admin-img-src').forEach(function (input) {
  var pid = input.getAttribute('data-lv-preview');
  var img = pid ? document.getElementById(pid) : null;
  function sync() {
    var v = (input.value || '').trim();
    if (!img) return;
    if (!v) { img.classList.add('hidden'); img.removeAttribute('src'); return; }
    img.classList.remove('hidden');
    img.src = v;
  }
  input.addEventListener('input', sync);
  input.addEventListener('change', sync);
  sync();
});
</script>
