@using LuxeVoyage.Mvc.Models
@model IEnumerable<LuxeVoyage.Mvc.Models.Destination>
<div class="admin-page-shell font-body-md">
<div class="admin-page-toolbar">
<h1 class="admin-page-title">Destinations</h1>
<a asp-action="Create" class="bg-primary text-on-primary font-label-sm text-label-sm px-6 py-3 rounded-lg hover:bg-primary/90 transition-colors inline-flex items-center gap-2 shadow-sm">New Destination</a>
</div>
<form method="get" class="admin-toolbar-search mb-4 js-admin-filter-form">
<input type="search" name="q" value="@((string?)ViewBag.SearchQuery ?? "")" placeholder="Search destinations..." class="w-[280px] max-w-full pl-4 pr-4 py-2 bg-surface-container-lowest border border-outline-variant rounded-lg h-[48px]" />
<button type="submit" class="admin-action-link">Search</button>
@if (!string.IsNullOrWhiteSpace((string?)ViewBag.SearchQuery))
{
    <a asp-action="Index" asp-route-showInactive="@ViewBag.ShowInactive" class="admin-action-link">Clear</a>
}
<label class="inline-flex items-center gap-2 text-sm text-slate-600 cursor-pointer">
<input type="checkbox" name="showInactive" value="true" class="rounded border-slate-400 js-auto-submit-inactive" @(ViewBag.ShowInactive == true ? "checked=\"checked\"" : null) />
Show inactive destinations
</label>
</form>
<div class="admin-table-card">
<div class="admin-table-wrap">
<table class="lv-admin-table">
<thead>
<tr>
<th>Destination</th><th>Region</th><th class="lv-admin-col-actions">Actions</th>
</tr>
</thead>
<tbody>
@if (!Model.Any())
{
<tr><td colspan="3" class="py-6"><div class="admin-empty-state"><h3>No results found</h3><p>Try adjusting your search term.</p></div></td></tr>
}
@foreach (var d in Model)
{
<tr class="@(d.IsActive ? "" : "opacity-80")">
<td>
<div class="admin-title-cell">
<div class="admin-thumb">
@if (!string.IsNullOrWhiteSpace(d.ImageUrl))
{
    <img src="@d.ImageUrl" alt="" />
}
else
{
    <span class="material-symbols-outlined">image</span>
}
</div>
<div>
<div class="admin-title-main">@d.Title @if (!d.IsActive){<span class="ml-2 rounded-full bg-slate-500/15 px-2 py-0.5 text-[11px] font-medium text-slate-600">Inactive</span>}</div>
<div class="admin-title-sub">Slug: @d.Slug</div>
</div>
</div>
</td>
<td>@CatalogQueryHelper.RegionDisplay(d.Region)</td>
<td class="lv-admin-col-actions">
<div class="admin-actions-wrap">
<a asp-action="Edit" asp-route-id="@d.Id" class="admin-pill admin-pill-edit">Edit</a>
@if (d.IsActive)
{
<form asp-action="Deactivate" asp-route-id="@d.Id" method="post" class="inline" onsubmit="return confirm('Deactivate this item? It will be hidden from the public catalog.');">
@Html.AntiForgeryToken()<input type="hidden" name="q" value="@ViewBag.SearchQuery" /><input type="hidden" name="showInactive" value="@(ViewBag.ShowInactive == true ? "true" : "false")" />
<button type="submit" class="admin-pill admin-pill-deactivate">Deactivate</button></form>
}
else
{
<form asp-action="Activate" asp-route-id="@d.Id" method="post" class="inline" onsubmit="return confirm('Activate this item? It will be visible in the public catalog.');">
@Html.AntiForgeryToken()<input type="hidden" name="q" value="@ViewBag.SearchQuery" /><input type="hidden" name="showInactive" value="@(ViewBag.ShowInactive == true ? "true" : "false")" />
<button type="submit" class="admin-pill admin-pill-activate">Activate</button></form>
}
<form asp-action="DeletePermanent" asp-route-id="@d.Id" method="post" class="inline" onsubmit="return confirm('Permanently delete this item? This cannot be undone.');">
@Html.AntiForgeryToken()<input type="hidden" name="q" value="@ViewBag.SearchQuery" /><input type="hidden" name="showInactive" value="@(ViewBag.ShowInactive == true ? "true" : "false")" />
<button type="submit" class="admin-pill admin-pill-delete">Delete</button></form>
</div>
</td>
</tr>
}
</tbody>
</table>
</div>
<div class="admin-table-footer"><span class="font-medium text-primary">@Model.Count()</span> destination@(Model.Count() == 1 ? "" : "s")</div>
</div>
</div>
<script>
(() => {
  const form = document.querySelector('.js-admin-filter-form');
  const checkbox = form?.querySelector('.js-auto-submit-inactive');
  if (!form || !checkbox) return;
  checkbox.addEventListener('change', () => form.submit());
})();
</script>
