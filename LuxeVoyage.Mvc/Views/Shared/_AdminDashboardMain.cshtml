@using LuxeVoyage.Mvc.Data
@using LuxeVoyage.Mvc.Models
@using LuxeVoyage.Mvc.Models.ViewModels
@model AdminDashboardMainViewModel
@inject ApplicationDbContext Db
@{
    var pendingReservations = Db.Bookings.Count(b => b.Status == BookingStatus.Pending);
}
<!-- TopAppBar -->
<header class="sticky top-0 w-full z-40 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 flex justify-between items-center px-8 h-16">
<div class="flex items-center gap-4">
<h1 class="font-h3 text-h3 text-slate-900 dark:text-white">Dashboard Overview</h1>
</div>
<div class="flex items-center gap-4">
<div class="relative hidden md:block">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
<input class="pl-10 pr-4 py-2 bg-surface-container-low border-none rounded-full text-sm w-64 focus:ring-2 focus:ring-primary focus:outline-none transition-shadow text-on-surface" placeholder="Search..." type="text"/>
</div>
<a asp-controller="AdminManageBookings" asp-action="Index" class="relative text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-full p-2 opacity-80 active:opacity-100 transition-all">
<span class="material-symbols-outlined text-[24px]">notifications</span>
@if (pendingReservations > 0)
{
    <span class="absolute -top-1 -right-1 min-w-[18px] h-[18px] rounded-full bg-amber-100 text-amber-700 text-[10px] leading-[18px] text-center px-1 font-semibold">@pendingReservations</span>
}
</a>
<button type="button" onclick="lvPlaceholder(event)" class="text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-full p-2 opacity-80 active:opacity-100 transition-all">
<span class="material-symbols-outlined text-[24px]">help_outline</span>
</button>
</div>
</header>
<!-- Main Canvas -->
<main class="flex-1 p-8 lg:p-12 space-y-lg">
<p class="text-sm text-on-surface-variant max-w-3xl mb-2 border border-amber-200/80 bg-amber-50 dark:bg-amber-950/30 rounded-xl px-4 py-3">@Model.DemoRevenueNote</p>
<!-- Stats -->
<section class="grid grid-cols-1 md:grid-cols-3 gap-6">
<div class="bg-surface-container-lowest rounded-xl p-6 shadow-[0_4px_20px_rgba(15,23,42,0.05)] flex flex-col justify-between relative overflow-hidden group">
<div class="flex justify-between items-start mb-4 relative z-10">
<div>
<p class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider mb-1">Demo revenue (USD)</p>
<h3 class="font-h2 text-h2 text-on-surface">$@Model.TotalPaidRevenueUsd.ToString("0.00")</h3>
</div>
<div class="w-10 h-10 rounded-full bg-tertiary-container/20 flex items-center justify-center text-tertiary">
<span class="material-symbols-outlined">payments</span>
</div>
</div>
<p class="text-xs text-on-surface-variant relative z-10">Total credited to LuxeVoyage admin account (simulation).</p>
<div class="absolute -bottom-6 -right-6 w-32 h-32 bg-tertiary-container/10 rounded-full blur-2xl group-hover:bg-tertiary-container/20 transition-colors"></div>
</div>
<div class="bg-surface-container-lowest rounded-xl p-6 shadow-[0_4px_20px_rgba(15,23,42,0.05)] flex flex-col justify-between relative overflow-hidden group">
<div class="flex justify-between items-start mb-4 relative z-10">
<div>
<p class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider mb-1">Paid bookings</p>
<h3 class="font-h2 text-h2 text-on-surface">@Model.PaidBookingsCount</h3>
</div>
<div class="w-10 h-10 rounded-full bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center text-emerald-700">
<span class="material-symbols-outlined">verified</span>
</div>
</div>
<p class="text-xs text-on-surface-variant relative z-10">Distinct reservations with a successful demo payment.</p>
<div class="absolute -bottom-6 -right-6 w-32 h-32 bg-emerald-500/5 rounded-full blur-2xl group-hover:bg-emerald-500/10 transition-colors"></div>
</div>
<div class="bg-surface-container-lowest rounded-xl p-6 shadow-[0_4px_20px_rgba(15,23,42,0.05)] flex flex-col justify-between relative overflow-hidden group">
<div class="flex justify-between items-start mb-4 relative z-10">
<div>
<p class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider mb-1">Open pipeline</p>
<h3 class="font-h2 text-h2 text-on-surface">@Model.PendingUnpaidRequestsCount</h3>
</div>
<div class="w-10 h-10 rounded-full bg-amber-100 dark:bg-amber-900/40 flex items-center justify-center text-amber-800">
<span class="material-symbols-outlined">hourglass_top</span>
</div>
</div>
<p class="text-xs text-on-surface-variant relative z-10">Awaiting staff review or accepted trips without a demo payment.</p>
<div class="absolute -bottom-6 -right-6 w-32 h-32 bg-amber-500/5 rounded-full blur-2xl group-hover:bg-amber-500/10 transition-colors"></div>
</div>
</section>
<!-- Recent demo payments -->
<section class="bg-surface-container-lowest rounded-xl shadow-[0_4px_20px_rgba(15,23,42,0.05)] overflow-hidden">
<div class="px-6 py-5 border-b border-surface-variant flex justify-between items-center">
<h3 class="font-h3 text-[20px] leading-snug font-semibold text-on-surface">Recent demo payments</h3>
<a asp-controller="AdminManageBookings" asp-action="Index" class="text-primary font-button text-sm hover:underline underline-offset-4 inline-block">Reservations</a>
</div>
<div class="overflow-x-auto">
@if (Model.RecentPaidPayments.Count == 0)
{
<div class="px-6 py-12 text-center text-on-surface-variant text-sm">No demo payments recorded yet.</div>
}
else
{
<table class="w-full text-left border-collapse">
<thead>
<tr class="bg-surface-container-low/50">
<th class="py-3 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider border-b border-surface-variant font-medium">Guest</th>
<th class="py-3 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider border-b border-surface-variant font-medium">Trip</th>
<th class="py-3 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider border-b border-surface-variant font-medium">Amount</th>
<th class="py-3 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider border-b border-surface-variant font-medium">Paid</th>
<th class="py-3 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider border-b border-surface-variant font-medium">Reference</th>
</tr>
</thead>
<tbody class="font-body-md text-sm text-on-surface">
@foreach (var r in Model.RecentPaidPayments)
{
<tr class="hover:bg-surface-container-low/30 transition-colors border-b border-surface-variant/50 last:border-0">
<td class="py-4 px-6 font-medium">@r.GuestEmail</td>
<td class="py-4 px-6">@r.ItemLabel</td>
<td class="py-4 px-6 font-semibold">@r.Currency $@r.Amount.ToString("0.00")</td>
<td class="py-4 px-6 text-on-surface-variant whitespace-nowrap">@(r.PaidAtUtc.HasValue ? r.PaidAtUtc.Value.ToString("MMM d, yyyy HH:mm") + " UTC" : "—")</td>
<td class="py-4 px-6 font-mono text-xs break-all max-w-[200px]">@(r.TransactionReference ?? "—")</td>
</tr>
}
</tbody>
</table>
}
</div>
</section>
