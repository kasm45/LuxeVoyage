@model IReadOnlyList<LuxeVoyage.Mvc.Models.ViewModels.AdminUserRowViewModel>
<div class="px-8 py-10 font-body-md">
    <h1 class="font-h2 text-h2 mb-2 text-slate-900 dark:text-white">Users &amp; Personnel</h1>
    <p class="text-slate-600 dark:text-slate-400 mb-4 text-sm max-w-2xl">Manage registered travelers, staff members, and admin access.</p>
    <div class="mb-6 flex flex-wrap gap-3 text-xs">
        <span class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-slate-700">Total users: @ViewBag.TotalUsers</span>
        <span class="rounded-full border border-orange-200 bg-orange-50 px-3 py-1.5 text-orange-700">Admin users: @ViewBag.AdminUsers</span>
        <span class="rounded-full border border-violet-200 bg-violet-50 px-3 py-1.5 text-violet-700">Personnel: @ViewBag.PersonnelUsers</span>
        <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1.5 text-slate-700">Travelers: @ViewBag.TravelerUsers</span>
    </div>
    @if (!string.IsNullOrWhiteSpace((string?)TempData["UsersMessage"]))
    {
        var isSuccess = string.Equals((string?)TempData["UsersMessageType"], "success", StringComparison.OrdinalIgnoreCase);
        <div class="mb-5 flex items-start gap-2 rounded-xl border px-4 py-3 text-sm @(isSuccess ? "border-emerald-200 bg-emerald-50 text-emerald-800" : "border-amber-200 bg-amber-50 text-amber-800")">
            <span class="material-symbols-outlined text-[18px] leading-none mt-0.5">@(isSuccess ? "check_circle" : "info")</span>
            <p class="m-0">@TempData["UsersMessage"]</p>
        </div>
    }
    <div class="bg-surface-container-lowest rounded-xl shadow-[0_4px_20px_rgba(15,23,42,0.05)] overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm border-collapse text-left">
                <thead>
                    <tr class="bg-surface-container-low/50">
                        <th class="py-3 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider border-b border-surface-variant font-medium">Email</th>
                        <th class="py-3 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider border-b border-surface-variant font-medium">Display Name</th>
                        <th class="py-3 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider border-b border-surface-variant font-medium">Role</th>
                        <th class="py-3 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider border-b border-surface-variant font-medium">Email Confirmed</th>
                        <th class="py-3 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider border-b border-surface-variant font-medium">Reservations</th>
                        <th class="py-3 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider border-b border-surface-variant font-medium">Favorites</th>
                        <th class="py-3 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider border-b border-surface-variant font-medium text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr><td colspan="7" class="py-6 px-6"><div class="admin-empty-state"><h3>No users yet</h3><p>User accounts will appear here after registration.</p></div></td></tr>
                    }
                    @foreach (var u in Model)
                    {
                        var currentUserId = (string?)ViewBag.CurrentUserId ?? "";
                        var disableRemoveAdmin = u.IsAdmin && u.Id == currentUserId && (int)(ViewBag.AdminUsers ?? 0) <= 1;
                        <tr class="border-b border-slate-100 dark:border-slate-800">
                            <td class="py-3 px-6 text-on-surface">@u.Email</td>
                            <td class="py-3 px-6 text-on-surface">@u.DisplayName</td>
                            <td class="py-3 px-6 text-on-surface">
                                @if (u.IsAdmin)
                                {
                                    <span class="inline-flex items-center rounded-full bg-slate-900 px-2.5 py-1 text-[11px] font-semibold text-white">Admin</span>
                                }
                                @if (u.IsPersonnel)
                                {
                                    <span class="ml-2 inline-flex items-center rounded-full border border-violet-200 bg-violet-50 px-2 py-0.5 text-[10px] font-semibold text-violet-700">Personnel</span>
                                }
                                @if (!u.IsAdmin && !u.IsPersonnel)
                                {
                                    <span class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-[11px] font-semibold text-slate-600">Traveler</span>
                                }
                            </td>
                            <td class="py-3 px-6">@(u.EmailConfirmed ? "Yes" : "No")</td>
                            <td class="py-3 px-6 text-on-surface">@u.ReservationsCount</td>
                            <td class="py-3 px-6 text-on-surface">@u.FavoritesCount</td>
                            <td class="py-3 px-6">
                                <div class="flex flex-wrap items-center justify-end gap-2 max-w-[420px] ml-auto">
                                @if (!u.IsAdmin)
                                {
                                    <form asp-controller="Admin" asp-action="MakeAdmin" asp-route-id="@u.Id" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1.5 text-xs font-semibold text-emerald-700 transition-colors hover:bg-emerald-100">Make Admin</button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-controller="Admin" asp-action="RemoveAdmin" asp-route-id="@u.Id" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="inline-flex items-center rounded-full border border-amber-200 bg-amber-50 px-3 py-1.5 text-xs font-semibold text-amber-700 transition-colors hover:bg-amber-100 @(disableRemoveAdmin ? "opacity-50 cursor-not-allowed" : "")" @(disableRemoveAdmin ? "disabled" : null)>Remove Admin</button>
                                    </form>
                                }
                                @if (!u.IsPersonnel)
                                {
                                    <form asp-controller="Admin" asp-action="MakePersonnel" asp-route-id="@u.Id" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="inline-flex items-center rounded-full border border-violet-200 bg-violet-50 px-3 py-1.5 text-xs font-semibold text-violet-700 transition-colors hover:bg-violet-100">Make Personnel</button>
                                    </form>
                                }
                                else if (u.Id != currentUserId)
                                {
                                    <form asp-controller="Admin" asp-action="RemovePersonnel" asp-route-id="@u.Id" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="inline-flex items-center rounded-full border border-violet-200 bg-violet-50 px-3 py-1.5 text-xs font-semibold text-violet-700 transition-colors hover:bg-violet-100">Remove Personnel</button>
                                    </form>
                                }
                                <form asp-controller="Admin" asp-action="DeleteUser" asp-route-id="@u.Id" method="post" class="inline" onsubmit="return confirm('Delete this user? This action cannot be undone.');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="inline-flex items-center rounded-full border border-rose-200 bg-rose-50 px-3 py-1.5 text-xs font-semibold text-rose-700 transition-colors hover:bg-rose-100 @(u.Id == currentUserId ? "opacity-50 cursor-not-allowed" : "")" @(u.Id == currentUserId ? "disabled" : null)>Delete</button>
                                </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
