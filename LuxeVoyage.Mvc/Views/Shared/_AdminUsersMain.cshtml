@model IReadOnlyList<LuxeVoyage.Mvc.Models.ViewModels.AdminUserRowViewModel>
<div class="px-8 py-10 font-body-md">
    <h1 class="font-h2 text-h2 mb-8 text-slate-900 dark:text-white">Users</h1>
    <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm max-w-2xl">Registered accounts (read-only). Roles reflect ASP.NET Identity assignments.</p>
    <div class="bg-surface-container-lowest rounded-xl shadow-[0_4px_20px_rgba(15,23,42,0.05)] overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm border-collapse text-left">
                <thead>
                    <tr class="bg-surface-container-low/50">
                        <th class="py-3 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider border-b border-surface-variant font-medium">Email</th>
                        <th class="py-3 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider border-b border-surface-variant font-medium">Display Name</th>
                        <th class="py-3 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider border-b border-surface-variant font-medium">Roles</th>
                        <th class="py-3 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider border-b border-surface-variant font-medium">Email Confirmed</th>
                        <th class="py-3 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider border-b border-surface-variant font-medium">Reservations</th>
                        <th class="py-3 px-6 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider border-b border-surface-variant font-medium">Favorites</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr><td colspan="6" class="py-6 px-6"><div class="admin-empty-state"><h3>No users yet</h3><p>User accounts will appear here after registration.</p></div></td></tr>
                    }
                    @foreach (var u in Model)
                    {
                        <tr class="border-b border-slate-100 dark:border-slate-800">
                            <td class="py-3 px-6 text-on-surface">@u.Email</td>
                            <td class="py-3 px-6 text-on-surface">@u.DisplayName</td>
                            <td class="py-3 px-6 text-on-surface">@u.RolesSummary</td>
                            <td class="py-3 px-6">@(u.EmailConfirmed ? "Yes" : "No")</td>
                            <td class="py-3 px-6 text-on-surface">@u.ReservationsCount</td>
                            <td class="py-3 px-6 text-on-surface">@u.FavoritesCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
