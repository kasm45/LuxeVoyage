@model LuxeVoyage.Mvc.Models.ExperienceDetailViewModel
@{
    var defaultHero = "https://lh3.googleusercontent.com/aida-public/AB6AXuCc4dfYie-oqEPanm7yfkDO5rCAnJN79GK_XC48gdA8QYwyWUiT4milx-US9sZ0QuIXA2BPL4KcgSwDkh_U7aS6jEgLIidIKDeEacLbXQvarAi1FlU4P7lsouNhlZm8ekFG68OVYRlAooPBmNiiHQxXloWv2kCJezJnnbGKbscy_5PD7boCOp4Nf0N0ubaCE9_J2Hw1xiYLBMBJQNtTehiVtPJLO7CojYhmdX3E9Afd2iBDVUpRKMXdVQHC2vQh2EfVTIuR0jRqwRo";
    var hero = string.IsNullOrWhiteSpace(Model.HeroImageUrl) ? defaultHero : Model.HeroImageUrl;
    var g1 = string.IsNullOrWhiteSpace(Model.GalleryImage1Url) ? hero : Model.GalleryImage1Url;
    var g2 = Model.GalleryImage2Url;
    var g3 = Model.GalleryImage3Url;
    var g4 = Model.GalleryImage4Url;
    var chips = string.IsNullOrWhiteSpace(Model.DetailTagline)
        ? Array.Empty<string>()
        : Model.DetailTagline.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    var bookingEyebrow = Model.DetailKind switch
    {
        "tour" => "Tour from",
        "stay" => "Stay from",
        _ => "Experience from"
    };
    var bookingSubcopy = Model.DetailKind switch
    {
        "tour" => "Reserve your curated itinerary with flexible planning support.",
        "stay" => "Check availability for your dates and receive a tailored stay plan.",
        _ => "Select your preferred date and group size to check availability."
    };
    var ctaText = Model.DetailKind == "tour" ? "Reserve this tour" : "Check Availability";
    var tripStart = DateTime.Today.AddDays(14).ToString("yyyy-MM-dd");
    var tripEnd = DateTime.Today.AddDays(21).ToString("yyyy-MM-dd");
}
<style>
  .lv-booking-card { background: #fff; border: 1px solid rgba(148, 106, 74, 0.18); border-radius: 18px; box-shadow: 0 10px 28px rgba(15, 23, 42, 0.08); padding: 1.1rem; display: flex; flex-direction: column; gap: 0.85rem; }
  .lv-booking-eyebrow { font-size: 0.73rem; text-transform: uppercase; letter-spacing: .08em; color: #9A6442; font-weight: 700; }
  .lv-booking-price { font-size: 2rem; line-height: 1.1; font-weight: 700; color: #1f2937; }
  .lv-booking-subcopy { font-size: 0.93rem; line-height: 1.45; color: #475569; border: 1px solid rgba(148, 106, 74, 0.18); background: #fffaf5; border-radius: 14px; padding: .7rem .8rem; }
  .lv-booking-cta { width: 100%; display: block; text-align: center; border-radius: 9999px; padding: .78rem 1rem; font-weight: 700; color: #fff; background: linear-gradient(180deg, #9A6442 0%, #7A4B31 100%); box-shadow: 0 8px 18px rgba(122, 75, 49, .25); transition: transform .15s ease, box-shadow .15s ease; }
  .lv-booking-cta:hover { transform: translateY(-1px); box-shadow: 0 11px 20px rgba(122, 75, 49, .32); }
  .lv-booking-meta { display: flex; flex-wrap: wrap; gap: .4rem; }
  .lv-booking-note { font-size: .74rem; border-radius: 9999px; padding: .28rem .56rem; background: #f8efe7; color: #7A4B31; }
  .lv-booking-rows { border-top: 1px solid rgba(148, 163, 184, .35); padding-top: .65rem; display: flex; flex-direction: column; gap: .46rem; }
  .lv-booking-row { display: flex; justify-content: space-between; gap: .8rem; font-size: .86rem; color: #334155; }
  .lv-booking-row span:last-child { font-weight: 600; color: #0f172a; text-align: right; }
</style>
<main class="pt-[104px] pb-xl max-w-container-max mx-auto px-gutter md:px-xl">
<nav class="flex flex-wrap items-center gap-2 mb-md text-on-surface-variant font-label-caps text-label-caps uppercase">
<a class="hover:text-primary transition-colors" asp-controller="@(Model.DetailKind == "tour" ? "Tours" : Model.DetailKind == "stay" ? "Hotels" : "Experiences")" asp-action="Index">@(Model.DetailKind == "tour" ? "Tours" : Model.DetailKind == "stay" ? "Stays" : "Experiences")</a>
<span class="material-symbols-outlined text-[16px]">chevron_right</span>
<span class="text-on-surface/80">@Model.BreadcrumbCity</span>
<span class="material-symbols-outlined text-[16px]">chevron_right</span>
<span class="text-on-surface">@Model.BreadcrumbCurrent</span>
</nav>

<header class="mb-lg">
<h1 class="font-h1 text-h1 text-on-surface mb-sm">@Model.Title</h1>
@if (!string.IsNullOrWhiteSpace(Model.HeroSubtitle)) { <p class="font-body-lg text-body-lg text-on-surface-variant mb-sm max-w-3xl">@Model.HeroSubtitle</p> }
<div class="flex flex-wrap items-center gap-md text-on-surface-variant font-body-md text-body-md">
<div class="flex items-center gap-1"><span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">star</span><span class="font-semibold text-on-surface">@(Model.Rating?.ToString("0.0") ?? "�")</span></div>
<div class="flex items-center gap-1"><span class="material-symbols-outlined text-[20px]">location_on</span><span>@Model.Location</span></div>
@if (chips.Any())
{
<div class="flex flex-wrap gap-2">@foreach (var c in chips.Take(4)) { <span class="bg-secondary-container/30 text-on-secondary-container px-3 py-1 rounded-full font-label-caps text-label-caps uppercase">@c</span> }</div>
}
</div>
</header>

<section id="lv-gallery" class="mb-xxl rounded-[16px] overflow-hidden shadow-[0_4px_20px_rgba(15,23,42,0.05)] border-[0.5px] border-white/10">
<div class="flex flex-col md:flex-row gap-unit md:gap-sm">
<div class="relative group overflow-hidden md:flex-[1.1] min-h-[220px]" data-lv-g-slot><img class="w-full h-full object-cover" alt="" src="@g1" onerror="this.closest('[data-lv-g-slot]')?.classList.add('hidden')" /></div>
<div class="flex flex-col gap-unit md:gap-sm md:flex-1">
@if (!string.IsNullOrWhiteSpace(g2)) { <div class="relative group overflow-hidden min-h-[160px]" data-lv-g-slot><img class="w-full h-full object-cover" alt="" src="@g2" onerror="this.closest('[data-lv-g-slot]')?.classList.add('hidden')" /></div> }
<div class="grid grid-cols-2 gap-unit md:gap-sm">
@if (!string.IsNullOrWhiteSpace(g3)) { <div class="relative group overflow-hidden min-h-[140px]" data-lv-g-slot><img class="w-full h-full object-cover" alt="" src="@g3" onerror="this.closest('[data-lv-g-slot]')?.classList.add('hidden')" /></div> }
@if (!string.IsNullOrWhiteSpace(g4)) { <div class="relative group overflow-hidden min-h-[140px]" data-lv-g-slot><img class="w-full h-full object-cover" alt="" src="@g4" onerror="this.closest('[data-lv-g-slot]')?.classList.add('hidden')" /></div> }
</div>
</div>
</div>
</section>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-xl">
<div class="lg:col-span-8 flex flex-col gap-xxl">
<section>
<h2 class="font-h2 text-h2 text-on-surface mb-lg">About</h2>
<p class="font-body-lg text-body-lg text-on-surface-variant whitespace-pre-line">@(string.IsNullOrWhiteSpace(Model.DetailDescription) ? Model.Summary : Model.DetailDescription)</p>
</section>
@if (!string.IsNullOrWhiteSpace(Model.IncludedItemsText)) { <section><h2 class="font-h2 text-h2 text-on-surface mb-lg">Included</h2><p class="font-body-md text-body-md text-on-surface-variant whitespace-pre-line">@Model.IncludedItemsText</p></section> }
@if (!string.IsNullOrWhiteSpace(Model.HighlightsText)) { <section><h2 class="font-h2 text-h2 text-on-surface mb-lg">Highlights</h2><p class="font-body-md text-body-md text-on-surface-variant whitespace-pre-line">@Model.HighlightsText</p></section> }
@if (!string.IsNullOrWhiteSpace(Model.ItineraryText)) { <section><h2 class="font-h2 text-h2 text-on-surface mb-lg">Itinerary</h2><p class="font-body-md text-body-md text-on-surface-variant whitespace-pre-line">@Model.ItineraryText</p></section> }
@if (!string.IsNullOrWhiteSpace(Model.NearbyAttractionsText)) { <section><h2 class="font-h2 text-h2 text-on-surface mb-lg">Nearby attractions</h2><p class="font-body-md text-body-md text-on-surface-variant whitespace-pre-line">@Model.NearbyAttractionsText</p></section> }
@if (!string.IsNullOrWhiteSpace(Model.WhatToBringText)) { <section><h2 class="font-h2 text-h2 text-on-surface mb-lg">What to bring</h2><p class="font-body-md text-body-md text-on-surface-variant whitespace-pre-line">@Model.WhatToBringText</p></section> }
@if (!string.IsNullOrWhiteSpace(Model.CheckInInfoText)) { <section><h2 class="font-h2 text-h2 text-on-surface mb-lg">Check-in info</h2><p class="font-body-md text-body-md text-on-surface-variant whitespace-pre-line">@Model.CheckInInfoText</p></section> }
@if (!string.IsNullOrWhiteSpace(Model.CancellationPolicyText)) { <section><h2 class="font-h2 text-h2 text-on-surface mb-lg">Cancellation policy</h2><p class="font-body-md text-body-md text-on-surface-variant whitespace-pre-line">@Model.CancellationPolicyText</p></section> }
</div>
<div class="lg:col-span-4 relative">
<div id="lv-booking-panel" class="sticky top-[120px]">
<div class="lv-booking-card">
<div class="lv-booking-eyebrow">@bookingEyebrow</div>
<div class="lv-booking-price">@Model.PriceDisplay</div>
<div class="lv-booking-subcopy">@bookingSubcopy</div>
@if (Model.NumericId is int nidExp && Model.DetailKind == "experience")
{
<form method="get" asp-controller="Bookings" asp-action="Create" class="flex flex-col gap-3">
<input type="hidden" name="experienceId" value="@nidExp" />
<div>
<label class="text-[11px] font-bold uppercase tracking-[0.08em] text-[#64748b]">Start date</label>
<input type="date" name="startDate" value="@tripStart" required class="mt-1 w-full rounded-xl border border-[rgba(148,106,74,0.35)] bg-white px-3 py-2.5 text-sm text-[#0f172a]" autocomplete="off" />
</div>
<div>
<label class="text-[11px] font-bold uppercase tracking-[0.08em] text-[#64748b]">End date</label>
<input type="date" name="endDate" value="@tripEnd" required class="mt-1 w-full rounded-xl border border-[rgba(148,106,74,0.35)] bg-white px-3 py-2.5 text-sm text-[#0f172a]" autocomplete="off" />
</div>
<div>
<label class="text-[11px] font-bold uppercase tracking-[0.08em] text-[#64748b]">Guests</label>
<input type="number" name="guests" value="2" min="1" max="20" required class="mt-1 w-full rounded-xl border border-[rgba(148,106,74,0.35)] bg-white px-3 py-2.5 text-sm text-[#0f172a]" autocomplete="off" />
</div>
<button type="submit" class="lv-booking-cta border-0 cursor-pointer">@ctaText</button>
</form>
}
else if (Model.NumericId is int nt && Model.DetailKind == "tour")
{
<form method="get" asp-controller="Bookings" asp-action="Create" class="flex flex-col gap-3">
<input type="hidden" name="tourId" value="@nt" />
<div>
<label class="text-[11px] font-bold uppercase tracking-[0.08em] text-[#64748b]">Start date</label>
<input type="date" name="startDate" value="@tripStart" required class="mt-1 w-full rounded-xl border border-[rgba(148,106,74,0.35)] bg-white px-3 py-2.5 text-sm text-[#0f172a]" autocomplete="off" />
</div>
<div>
<label class="text-[11px] font-bold uppercase tracking-[0.08em] text-[#64748b]">End date</label>
<input type="date" name="endDate" value="@tripEnd" required class="mt-1 w-full rounded-xl border border-[rgba(148,106,74,0.35)] bg-white px-3 py-2.5 text-sm text-[#0f172a]" autocomplete="off" />
</div>
<div>
<label class="text-[11px] font-bold uppercase tracking-[0.08em] text-[#64748b]">Guests</label>
<input type="number" name="guests" value="2" min="1" max="20" required class="mt-1 w-full rounded-xl border border-[rgba(148,106,74,0.35)] bg-white px-3 py-2.5 text-sm text-[#0f172a]" autocomplete="off" />
</div>
<button type="submit" class="lv-booking-cta border-0 cursor-pointer">@ctaText</button>
</form>
}
else if (Model.NumericId is int ns && Model.DetailKind == "stay")
{
<form method="get" asp-controller="Bookings" asp-action="Create" class="flex flex-col gap-3">
<input type="hidden" name="stayId" value="@ns" />
<div>
<label class="text-[11px] font-bold uppercase tracking-[0.08em] text-[#64748b]">Check-in</label>
<input type="date" name="startDate" value="@tripStart" required class="mt-1 w-full rounded-xl border border-[rgba(148,106,74,0.35)] bg-white px-3 py-2.5 text-sm text-[#0f172a]" autocomplete="off" />
</div>
<div>
<label class="text-[11px] font-bold uppercase tracking-[0.08em] text-[#64748b]">Check-out</label>
<input type="date" name="endDate" value="@tripEnd" required class="mt-1 w-full rounded-xl border border-[rgba(148,106,74,0.35)] bg-white px-3 py-2.5 text-sm text-[#0f172a]" autocomplete="off" />
</div>
<div>
<label class="text-[11px] font-bold uppercase tracking-[0.08em] text-[#64748b]">Guests</label>
<input type="number" name="guests" value="2" min="1" max="20" required class="mt-1 w-full rounded-xl border border-[rgba(148,106,74,0.35)] bg-white px-3 py-2.5 text-sm text-[#0f172a]" autocomplete="off" />
</div>
<button type="submit" class="lv-booking-cta border-0 cursor-pointer">Check Availability</button>
</form>
}
@if (Model.NumericId is int cartId && Model.DetailKind is "experience" or "tour" or "stay")
{
    var basketReturn = $"{Context.Request.Path}{Context.Request.QueryString}";
    var basketKind = Model.DetailKind switch { "experience" => "Experience", "tour" => "Tour", "stay" => "Stay", _ => "" };
    if (!string.IsNullOrEmpty(basketKind))
    {
<div class="mt-3 flex justify-center w-full">
<partial name="_AddToCartButton" model="new LuxeVoyage.Mvc.Models.ViewModels.AddToCartButtonModel { ItemType = basketKind, ItemId = cartId, ReturnUrl = basketReturn }" />
</div>
    }
}
<div class="lv-booking-meta">
<span class="lv-booking-note">No charge today</span>
<span class="lv-booking-note">Secure request</span>
<span class="lv-booking-note">Concierge support included</span>
</div>
<div class="lv-booking-rows">
@if (Model.DetailKind == "experience")
{
    @if (!string.IsNullOrWhiteSpace(Model.DurationDisplay)) { <div class="lv-booking-row"><span>Duration</span><span>@Model.DurationDisplay</span></div> }
    @if (!string.IsNullOrWhiteSpace(Model.GroupSizeDisplay)) { <div class="lv-booking-row"><span>Group size</span><span>@Model.GroupSizeDisplay</span></div> }
    <div class="lv-booking-row"><span>Starting price</span><span>@Model.PriceDisplay</span></div>
}
else if (Model.DetailKind == "tour")
{
    @if (Model.DurationDays is int d) { <div class="lv-booking-row"><span>Duration</span><span>@d days</span></div> }
    else if (!string.IsNullOrWhiteSpace(Model.DurationDisplay)) { <div class="lv-booking-row"><span>Duration</span><span>@Model.DurationDisplay</span></div> }
    @if (!string.IsNullOrWhiteSpace(Model.GroupSizeDisplay)) { <div class="lv-booking-row"><span>Group size</span><span>@Model.GroupSizeDisplay</span></div> }
    @if (!string.IsNullOrWhiteSpace(Model.Location)) { <div class="lv-booking-row"><span>Route</span><span>@Model.Location</span></div> }
    <div class="lv-booking-row"><span>Starting price</span><span>@Model.PriceDisplay</span></div>
}
else if (Model.DetailKind == "stay")
{
    <div class="lv-booking-row"><span>Price per night</span><span>@Model.PriceDisplay</span></div>
    @if (!string.IsNullOrWhiteSpace(Model.GroupSizeDisplay)) { <div class="lv-booking-row"><span>Guest capacity</span><span>@Model.GroupSizeDisplay</span></div> }
    @if (!string.IsNullOrWhiteSpace(Model.RoomTypeText)) { <div class="lv-booking-row"><span>Room type</span><span>@Model.RoomTypeText</span></div> }
}
</div>
</div>
</div>
</div>
</main>
