@model LuxeVoyage.Mvc.Models.Tour
<div class="space-y-8 max-w-3xl">
<div asp-validation-summary="All" class="text-red-600 text-sm"></div>
<section class="space-y-4 border-b border-slate-200 dark:border-slate-700 pb-6"><h2 class="font-h3 text-lg font-semibold">Basics</h2><div><label class="block text-sm font-medium">Title</label><input asp-for="Title" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Slug</label><input asp-for="Slug" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" /></div><div class="grid grid-cols-1 md:grid-cols-2 gap-4"><div><label class="block text-sm font-medium">Category/type</label><input asp-for="CategoryLabel" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Region</label><select asp-for="Region" asp-items="Html.GetEnumSelectList<LuxeVoyage.Mvc.Models.RegionKind>()" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></select></div></div><label class="inline-flex items-center gap-2"><input type="checkbox" asp-for="IsActive" class="rounded" /> Active</label></section>
<section class="space-y-4 border-b border-slate-200 dark:border-slate-700 pb-6"><h2 class="font-h3 text-lg font-semibold">Listing card settings</h2><label class="inline-flex items-center gap-2"><input type="checkbox" asp-for="IsVisibleOnListing" class="rounded" /> Show on listing</label><div><label class="block text-sm font-medium">Card title</label><input asp-for="CardTitle" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Card summary</label><textarea asp-for="CardSummary" rows="3" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea></div><div><label class="block text-sm font-medium">Card image URL</label><input asp-for="CardImageUrl" data-lv-preview="tour-card" class="js-lv-preview mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" /><img id="tour-card" class="hidden mt-2 max-h-36 rounded-lg border object-cover" /></div><div class="grid grid-cols-1 md:grid-cols-2 gap-4"><div><label class="block text-sm font-medium">Card badge</label><input asp-for="CardBadge" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Card region display</label><input asp-for="CardRegion" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div></div><div class="grid grid-cols-1 md:grid-cols-2 gap-4"><div><label class="block text-sm font-medium">Price</label><input asp-for="Price" type="number" step="1" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Price hint</label><input asp-for="CardPriceHint" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div></div><div class="grid grid-cols-1 md:grid-cols-2 gap-4"><div><label class="block text-sm font-medium">Duration (days)</label><input asp-for="DurationDays" type="number" min="1" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Rating</label><input asp-for="CardRating" type="number" step="0.1" min="0" max="5" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div></div></section>
<section class="space-y-4 border-b border-slate-200 dark:border-slate-700 pb-6"><h2 class="font-h3 text-lg font-semibold">Tour detail page</h2><div><label class="block text-sm font-medium">Hero title</label><input asp-for="HeroTitle" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Hero subtitle</label><input asp-for="HeroSubtitle" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Hero image URL</label><input asp-for="HeroImageUrl" data-lv-preview="tour-hero" class="js-lv-preview mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" /><img id="tour-hero" class="hidden mt-2 max-h-36 rounded-lg border object-cover" /></div><div><label class="block text-sm font-medium">Detail description</label><textarea asp-for="DetailDescription" rows="6" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea></div><div><label class="block text-sm font-medium">Detail tagline / chips</label><input asp-for="DetailTagline" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div class="grid grid-cols-1 md:grid-cols-3 gap-4"><div><label class="block text-sm font-medium">Destination/location label</label><input asp-for="DestinationLabel" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Group size</label><input asp-for="GroupSizeText" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Starting price hint</label><input asp-for="CardPriceHint" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div></div><div><label class="block text-sm font-medium">Included items</label><textarea asp-for="IncludedItemsCsv" rows="3" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea></div><div><label class="block text-sm font-medium">Highlights</label><textarea asp-for="HighlightsCsv" rows="3" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea></div><div><label class="block text-sm font-medium">Itinerary</label><textarea asp-for="ItineraryText" rows="5" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea></div><div><label class="block text-sm font-medium">What to bring</label><textarea asp-for="WhatToBring" rows="3" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea></div><div><label class="block text-sm font-medium">Cancellation policy</label><textarea asp-for="CancellationPolicy" rows="3" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea></div><div class="grid grid-cols-1 md:grid-cols-2 gap-4"><div><label class="block text-sm font-medium">Gallery image 1 URL</label><input asp-for="GalleryImage1Url" data-lv-preview="tour-g1" class="js-lv-preview mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" /><img id="tour-g1" class="hidden mt-2 max-h-32 rounded-lg border object-cover" /></div><div><label class="block text-sm font-medium">Gallery image 2 URL</label><input asp-for="GalleryImage2Url" data-lv-preview="tour-g2" class="js-lv-preview mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" /><img id="tour-g2" class="hidden mt-2 max-h-32 rounded-lg border object-cover" /></div><div><label class="block text-sm font-medium">Gallery image 3 URL</label><input asp-for="GalleryImage3Url" data-lv-preview="tour-g3" class="js-lv-preview mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" /><img id="tour-g3" class="hidden mt-2 max-h-32 rounded-lg border object-cover" /></div><div><label class="block text-sm font-medium">Gallery image 4 URL</label><input asp-for="GalleryImage4Url" data-lv-preview="tour-g4" class="js-lv-preview mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" /><img id="tour-g4" class="hidden mt-2 max-h-32 rounded-lg border object-cover" /></div></div></section>
<section class="space-y-4 pb-6"><h2 class="font-h3 text-lg font-semibold">Legacy / fallback fields</h2><div><label class="block text-sm font-medium">Legacy image URL</label><input asp-for="ImageUrl" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" /></div><div><label class="block text-sm font-medium">Legacy summary</label><textarea asp-for="Summary" rows="3" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea></div><div><label class="block text-sm font-medium">Legacy rating</label><input asp-for="Rating" type="number" step="0.1" min="0" max="5" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div></section>
</div>
<script>document.querySelectorAll('.js-lv-preview').forEach(i=>{const id=i.getAttribute('data-lv-preview');const img=document.getElementById(id);const s=()=>{const v=(i.value||'').trim();if(!img)return;if(!v){img.classList.add('hidden');img.removeAttribute('src');return;}img.src=v;img.classList.remove('hidden');};i.addEventListener('input',s);s();});</script>
