@model LuxeVoyage.Mvc.Models.Experience
<div class="px-8 py-10 font-body-md">
<h1 class="font-h2 text-h2 mb-6">Edit experience</h1>
<form asp-action="Edit" method="post">
@Html.AntiForgeryToken()
<input type="hidden" asp-for="Id" />
@await Html.PartialAsync("_ExperienceForm", Model)
<div class="mt-8 flex gap-4">
<button type="submit" class="rounded-lg bg-primary px-6 py-2 text-on-primary">Save</button>
<a asp-action="Index" class="rounded-lg border px-6 py-2">Cancel</a>
</div>
</form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
