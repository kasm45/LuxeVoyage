@model LuxeVoyage.Mvc.Models.Experience
<div class="space-y-4 max-w-xl">
<div asp-validation-summary="All" class="text-red-600 text-sm"></div>
<div>
<label class="block text-sm font-medium">Title</label>
<input asp-for="Title" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" />
</div>
<div>
<label class="block text-sm font-medium">Slug</label>
<input asp-for="Slug" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" />
</div>
<div>
<label class="block text-sm font-medium">Category</label>
<select asp-for="Category" asp-items="Html.GetEnumSelectList<LuxeVoyage.Mvc.Models.ExperienceCategoryKind>()" class="mt-1 w-full rounded border px-3 py-2 dark:bg-slate-900"></select>
</div>
<div>
<label class="block text-sm font-medium">Region</label>
<select asp-for="Region" asp-items="Html.GetEnumSelectList<LuxeVoyage.Mvc.Models.RegionKind>()" class="mt-1 w-full rounded border px-3 py-2 dark:bg-slate-900"></select>
</div>
<div>
<label class="block text-sm font-medium">Image URL</label>
<input asp-for="ImageUrl" class="mt-1 w-full rounded border px-3 py-2 dark:bg-slate-900" />
</div>
<div>
<label class="block text-sm font-medium">Summary</label>
<textarea asp-for="Summary" rows="3" class="mt-1 w-full rounded border px-3 py-2 dark:bg-slate-900"></textarea>
</div>
<div>
<label class="block text-sm font-medium">Location label</label>
<input asp-for="LocationLabel" class="mt-1 w-full rounded border px-3 py-2 dark:bg-slate-900" />
</div>
<div>
<label class="block text-sm font-medium">Rating</label>
<input asp-for="Rating" type="number" step="0.1" class="mt-1 w-full rounded border px-3 py-2 dark:bg-slate-900" />
</div>
<div>
<label class="block text-sm font-medium">Price hint</label>
<input asp-for="PriceHint" class="mt-1 w-full rounded border px-3 py-2 dark:bg-slate-900" />
</div>
<div>
<label class="block text-sm font-medium">Breadcrumb region</label>
<input asp-for="BreadcrumbRegion" class="mt-1 w-full rounded border px-3 py-2 dark:bg-slate-900" />
</div>
<div>
<label class="block text-sm font-medium">Breadcrumb city</label>
<input asp-for="BreadcrumbCity" class="mt-1 w-full rounded border px-3 py-2 dark:bg-slate-900" />
</div>
<div>
<label class="block text-sm font-medium">Breadcrumb current</label>
<input asp-for="BreadcrumbCurrent" class="mt-1 w-full rounded border px-3 py-2 dark:bg-slate-900" />
</div>
<div>
<label class="block text-sm font-medium">Tag line</label>
<input asp-for="TagLine" class="mt-1 w-full rounded border px-3 py-2 dark:bg-slate-900" />
</div>
</div>
