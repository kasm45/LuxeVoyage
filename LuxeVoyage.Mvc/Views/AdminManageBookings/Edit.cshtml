@model LuxeVoyage.Mvc.Models.Booking
<div class="px-8 py-10 font-body-md max-w-xl">
<h1 class="font-h2 text-h2 mb-6">Edit reservation #@Model.Id</h1>
<form asp-action="Edit" method="post" class="space-y-4">
@Html.AntiForgeryToken()
<input type="hidden" asp-for="Id" />
<label class="block text-sm">Start<input asp-for="StartDate" type="date" class="mt-1 w-full rounded border px-3 py-2 dark:bg-slate-900" /></label>
<label class="block text-sm">End<input asp-for="EndDate" type="date" class="mt-1 w-full rounded border px-3 py-2 dark:bg-slate-900" /></label>
<label class="block text-sm">Guests<input asp-for="Guests" type="number" min="1" max="20" class="mt-1 w-full rounded border px-3 py-2 dark:bg-slate-900" /></label>
<label class="block text-sm">Status<select asp-for="Status" asp-items="Html.GetEnumSelectList<LuxeVoyage.Mvc.Models.BookingStatus>()" class="mt-1 w-full rounded border px-3 py-2 dark:bg-slate-900"></select></label>
<label class="block text-sm">Notes<textarea asp-for="Notes" rows="3" class="mt-1 w-full rounded border px-3 py-2 dark:bg-slate-900" spellcheck="false" autocomplete="off"></textarea></label>
<div class="flex gap-4 pt-4"><button type="submit" class="rounded-lg bg-primary px-6 py-2 text-on-primary">Save</button><a asp-action="Index" class="rounded-lg border px-6 py-2">Cancel</a></div>
</form>
</div>
