@model IEnumerable<LuxeVoyage.Mvc.Models.Booking>
<div class="px-8 py-10 font-body-md">
<h1 class="font-h2 text-h2 mb-8 text-slate-900 dark:text-white">Reservations</h1>
@if (!string.IsNullOrWhiteSpace((string?)TempData["Message"]))
{
<div class="mb-5 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
    @TempData["Message"]
</div>
}
<div class="admin-table-wrap">
<table class="w-full text-sm border-collapse">
<thead class="border-b text-slate-500"><tr><th class="py-3 text-left">Id</th><th class="py-3">Guest</th><th class="py-3">Item</th><th class="py-3">Dates</th><th class="py-3">Status</th><th class="py-3"></th></tr></thead>
<tbody>
@if (!Model.Any())
{
<tr><td colspan="6" class="py-6"><div class="admin-empty-state"><h3>No reservations yet</h3><p>Reservations will appear here once guests submit requests.</p></div></td></tr>
}
@foreach (var b in Model)
{
var item = b.Tour?.Title ?? b.Stay?.Name ?? b.Experience?.Title ?? b.Destination?.Title ?? "—";
var statusClass = b.Status switch
{
    LuxeVoyage.Mvc.Models.BookingStatus.Pending => "admin-status-pending",
    LuxeVoyage.Mvc.Models.BookingStatus.Accepted => "admin-status-confirmed",
    LuxeVoyage.Mvc.Models.BookingStatus.Rejected => "admin-status-cancelled",
    _ => "admin-status-pending"
};
<tr class="border-b border-slate-100 dark:border-slate-800">
<td class="py-3">#@b.Id</td>
<td class="py-3">@(b.User?.Email ?? b.UserId)</td>
<td class="py-3 max-w-[200px] truncate" title="@item">@item</td>
<td class="py-3 whitespace-nowrap">@b.StartDate.ToString("MMM d") – @b.EndDate.ToString("MMM d")</td>
<td class="py-3"><span class="admin-status-badge @statusClass">@b.Status</span></td>
<td class="py-3 whitespace-nowrap">
<div class="admin-row-actions">
@if (b.Status == LuxeVoyage.Mvc.Models.BookingStatus.Pending)
{
    <form asp-action="Accept" asp-route-id="@b.Id" method="post" class="inline" onsubmit="return confirm('Accept this reservation request?');">
        @Html.AntiForgeryToken()
        <button type="submit" class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1.5 text-xs font-semibold text-emerald-700 transition-colors hover:bg-emerald-100">Accept</button>
    </form>
    <form asp-action="Reject" asp-route-id="@b.Id" method="post" class="inline" onsubmit="return confirm('Reject this reservation request?');">
        @Html.AntiForgeryToken()
        <button type="submit" class="inline-flex items-center rounded-full border border-rose-200 bg-rose-50 px-3 py-1.5 text-xs font-semibold text-rose-700 transition-colors hover:bg-rose-100">Reject</button>
    </form>
}
else if (b.Status == LuxeVoyage.Mvc.Models.BookingStatus.Accepted)
{
    <span class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1.5 text-xs font-semibold text-emerald-700">Accepted</span>
}
else if (b.Status == LuxeVoyage.Mvc.Models.BookingStatus.Rejected)
{
    <span class="inline-flex items-center rounded-full border border-rose-200 bg-rose-50 px-3 py-1.5 text-xs font-semibold text-rose-700">Rejected</span>
}
</div>
</td>
</tr>
}
</tbody>
</table>
</div>
</div>
