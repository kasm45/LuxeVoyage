@model LuxeVoyage.Mvc.Models.Stay
<div class="space-y-8 max-w-3xl">
<div asp-validation-summary="All" class="text-red-600 text-sm"></div>
<section class="space-y-4 border-b border-slate-200 dark:border-slate-700 pb-6"><h2 class="font-h3 text-lg font-semibold">Basics</h2><div><label class="block text-sm font-medium">Title</label><input asp-for="Name" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Slug</label><input asp-for="Slug" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" /></div><div class="grid grid-cols-1 md:grid-cols-2 gap-4"><div><label class="block text-sm font-medium">Stay type/category</label><input asp-for="StayType" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Region</label><select asp-for="Region" asp-items="Html.GetEnumSelectList<LuxeVoyage.Mvc.Models.RegionKind>()" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></select></div></div><label class="inline-flex items-center gap-2"><input type="checkbox" asp-for="IsActive" class="rounded" /> Active</label></section>
<section class="space-y-4 border-b border-slate-200 dark:border-slate-700 pb-6"><h2 class="font-h3 text-lg font-semibold">Listing card settings</h2><label class="inline-flex items-center gap-2"><input type="checkbox" asp-for="IsVisibleOnListing" class="rounded" /> Show on listing</label><div><label class="block text-sm font-medium">Card title</label><input asp-for="CardTitle" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Card summary</label><textarea asp-for="CardSummary" rows="3" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea></div><div><label class="block text-sm font-medium">Card image URL</label><input asp-for="CardImageUrl" data-lv-preview="stay-card" class="js-lv-preview mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" /><img id="stay-card" class="hidden mt-2 max-h-36 rounded-lg border object-cover" /></div><div class="grid grid-cols-1 md:grid-cols-2 gap-4"><div><label class="block text-sm font-medium">Card badge</label><input asp-for="CardBadge" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Card region/location display</label><input asp-for="CardRegion" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div></div><div class="grid grid-cols-1 md:grid-cols-2 gap-4"><div><label class="block text-sm font-medium">Price per night</label><input asp-for="PricePerNight" type="number" step="1" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Price hint</label><input asp-for="CardPriceHint" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div></div><div class="grid grid-cols-1 md:grid-cols-2 gap-4"><div><label class="block text-sm font-medium">Rating</label><input asp-for="CardRating" type="number" step="0.1" min="0" max="5" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Star rating (legacy)</label><input asp-for="StarRating" type="number" min="1" max="5" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div></div></section>
<section class="space-y-4 border-b border-slate-200 dark:border-slate-700 pb-6"><h2 class="font-h3 text-lg font-semibold">Stay detail page</h2><div><label class="block text-sm font-medium">Hero title</label><input asp-for="HeroTitle" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Hero subtitle</label><input asp-for="HeroSubtitle" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Hero image URL</label><input asp-for="HeroImageUrl" data-lv-preview="stay-hero" class="js-lv-preview mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" /><img id="stay-hero" class="hidden mt-2 max-h-36 rounded-lg border object-cover" /></div><div><label class="block text-sm font-medium">Detail description</label><textarea asp-for="DetailDescription" rows="6" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea></div><div><label class="block text-sm font-medium">Detail tagline / chips</label><input asp-for="DetailTagline" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div class="grid grid-cols-1 md:grid-cols-2 gap-4"><div><label class="block text-sm font-medium">Address/location label</label><input asp-for="AddressLabel" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Room type</label><input asp-for="RoomType" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div></div><div class="grid grid-cols-1 md:grid-cols-2 gap-4"><div><label class="block text-sm font-medium">Guest capacity</label><input asp-for="GuestCapacity" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Bed information</label><input asp-for="BedInfo" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div></div><div><label class="block text-sm font-medium">Amenities</label><textarea asp-for="AmenitiesDetailCsv" rows="3" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea></div><div><label class="block text-sm font-medium">Highlights</label><textarea asp-for="HighlightsCsv" rows="3" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea></div><div><label class="block text-sm font-medium">Nearby attractions</label><textarea asp-for="NearbyAttractionsCsv" rows="3" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea></div><div><label class="block text-sm font-medium">Check-in information</label><textarea asp-for="CheckInInfo" rows="3" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea></div><div><label class="block text-sm font-medium">Cancellation policy</label><textarea asp-for="CancellationPolicy" rows="3" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900"></textarea></div><div class="grid grid-cols-1 md:grid-cols-2 gap-4"><div><label class="block text-sm font-medium">Gallery image 1 URL</label><input asp-for="GalleryImage1Url" data-lv-preview="stay-g1" class="js-lv-preview mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" /><img id="stay-g1" class="hidden mt-2 max-h-32 rounded-lg border object-cover" /></div><div><label class="block text-sm font-medium">Gallery image 2 URL</label><input asp-for="GalleryImage2Url" data-lv-preview="stay-g2" class="js-lv-preview mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" /><img id="stay-g2" class="hidden mt-2 max-h-32 rounded-lg border object-cover" /></div><div><label class="block text-sm font-medium">Gallery image 3 URL</label><input asp-for="GalleryImage3Url" data-lv-preview="stay-g3" class="js-lv-preview mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" /><img id="stay-g3" class="hidden mt-2 max-h-32 rounded-lg border object-cover" /></div><div><label class="block text-sm font-medium">Gallery image 4 URL</label><input asp-for="GalleryImage4Url" data-lv-preview="stay-g4" class="js-lv-preview mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" /><img id="stay-g4" class="hidden mt-2 max-h-32 rounded-lg border object-cover" /></div></div></section>
<section class="space-y-4 pb-6"><h2 class="font-h3 text-lg font-semibold">Legacy / fallback fields</h2><div><label class="block text-sm font-medium">Legacy city/location</label><input asp-for="CityLine" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div><div><label class="block text-sm font-medium">Legacy image URL</label><input asp-for="ImageUrl" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900 font-mono text-sm" /></div><div><label class="block text-sm font-medium">Legacy amenities CSV</label><input asp-for="AmenitiesCsv" class="mt-1 w-full rounded border border-slate-300 px-3 py-2 dark:bg-slate-900" /></div></section>
</div>
<script>document.querySelectorAll('.js-lv-preview').forEach(i=>{const id=i.getAttribute('data-lv-preview');const img=document.getElementById(id);const s=()=>{const v=(i.value||'').trim();if(!img)return;if(!v){img.classList.add('hidden');img.removeAttribute('src');return;}img.src=v;img.classList.remove('hidden');};i.addEventListener('input',s);s();});</script>
