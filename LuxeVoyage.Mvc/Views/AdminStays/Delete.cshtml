@model LuxeVoyage.Mvc.Models.Stay
<div class="px-8 py-10 font-body-md max-w-xl">
<h1 class="font-h2 text-h2 mb-4">Delete stay</h1>
<p class="mb-6">Remove <strong>@Model.Name</strong>?</p>
<form asp-action="Delete" method="post">
@Html.AntiForgeryToken()
<input type="hidden" asp-for="Id" />
<button type="submit" class="rounded-lg bg-red-600 text-white px-6 py-2 mr-4">Delete</button>
<a asp-action="Index" class="rounded-lg border px-6 py-2">Cancel</a>
</form>
</div>
