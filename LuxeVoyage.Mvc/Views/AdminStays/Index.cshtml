@model IEnumerable<LuxeVoyage.Mvc.Models.Stay>
<div class="px-8 py-10 font-body-md">
<div class="flex justify-between mb-8">
<h1 class="font-h2 text-h2 text-slate-900 dark:text-white">Stays</h1>
<a asp-action="Create" class="rounded-lg bg-primary px-4 py-2 text-on-primary text-sm">New stay</a>
</div>
<form method="get" class="mb-5 flex flex-wrap items-center gap-3">
<input type="search" name="q" value="@((string?)ViewBag.SearchQuery ?? "")" placeholder="Search stays" class="min-w-[260px] rounded-lg border border-outline-variant px-4 py-2" />
<button type="submit" class="admin-action-link">Search</button>
@if (!string.IsNullOrWhiteSpace((string?)ViewBag.SearchQuery))
{
<a asp-action="Index" class="admin-action-link">Clear search</a>
}
</form>
<div class="admin-table-wrap">
<table class="w-full text-sm border-collapse">
<thead class="border-b text-slate-500"><tr><th class="py-3 text-left">Name</th><th class="py-3">Nightly</th><th class="py-3">Stars</th><th class="py-3">Actions</th></tr></thead>
<tbody>
@if (!Model.Any())
{
<tr><td colspan="4" class="py-6"><div class="admin-empty-state"><h3>No results found</h3><p>Try adjusting your search term or clear the search.</p></div></td></tr>
}
@foreach (var s in Model)
{
<tr class="border-b border-slate-100 dark:border-slate-800">
<td class="py-3 font-medium">@s.Name</td>
<td class="py-3">$@s.PricePerNight.ToString("0")</td>
<td class="py-3">@s.StarRating</td>
<td class="py-3">
<div class="admin-row-actions">
<a asp-action="Details" asp-route-id="@s.Id" class="admin-action-link">Details</a>
<a asp-action="Edit" asp-route-id="@s.Id" class="admin-action-link">Edit</a>
<a asp-action="Delete" asp-route-id="@s.Id" class="admin-action-link admin-action-danger">Delete</a>
</div>
</td>
</tr>
}
</tbody>
</table>
</div>
</div>
