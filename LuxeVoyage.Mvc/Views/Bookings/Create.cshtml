@model LuxeVoyage.Mvc.Models.ViewModels.BookingCreateViewModel
@{
    ViewBag.NavSection = "Book";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<main class="pt-28 pb-14 px-gutter max-w-[720px] mx-auto">
<section class="bg-surface-container-lowest border border-outline-variant rounded-2xl shadow-[0_18px_45px_rgba(15,23,42,0.08)] px-6 md:px-8 py-8">
<h1 class="font-h1 text-h1 text-on-background mb-2">Request your trip</h1>
<p class="font-body-md text-body-md text-on-surface-variant mb-8">
@if (!string.IsNullOrEmpty(Model.TourTitle))
{
<span>Tour: <strong class="text-on-surface">@Model.TourTitle</strong></span>
}
else if (!string.IsNullOrEmpty(Model.StayName))
{
<span>Stay: <strong class="text-on-surface">@Model.StayName</strong></span>
}
else if (!string.IsNullOrEmpty(Model.ExperienceTitle))
{
<span>Experience: <strong class="text-on-surface">@Model.ExperienceTitle</strong></span>
}
else if (!string.IsNullOrEmpty(Model.DestinationTitle))
{
<span>Destination: <strong class="text-on-surface">@Model.DestinationTitle</strong></span>
}
@if (Model.PriceHint is { } ph)
{
<span class="block mt-2">Reference from $@ph.ToString("0") — your concierge confirms the final fare.</span>
}
else if (!string.IsNullOrEmpty(Model.DestinationTitle))
{
<span class="block mt-2">Itineraries are priced to your dates and group — we’ll share a tailored quote after you submit.</span>
}
@if (Model.MinGuests is int minGuests && Model.MaxGuests is int maxGuests)
{
    var rangeLabel = minGuests == maxGuests ? $"{minGuests}" : $"{minGuests}-{maxGuests}";
<span class="block mt-2">Suggested group size: @rangeLabel guests.</span>
}
</p>

<form asp-controller="Bookings" asp-action="Create" method="post" class="space-y-5" data-booking-capacity-form>
@Html.AntiForgeryToken()
<input type="hidden" asp-for="TourId" />
<input type="hidden" asp-for="StayId" />
<input type="hidden" asp-for="ExperienceId" />
<input type="hidden" asp-for="DestinationId" />

<div>
<label asp-for="StartDate" class="font-label-sm text-label-sm text-on-surface block mb-1"></label>
<input asp-for="StartDate" class="w-full rounded-xl border border-outline-variant bg-surface-container-low px-4 py-3 min-h-[48px]" type="date" autocomplete="off" />
<span asp-validation-for="StartDate" class="text-error text-sm"></span>
</div>
<div>
<label asp-for="EndDate" class="font-label-sm text-label-sm text-on-surface block mb-1"></label>
<input asp-for="EndDate" class="w-full rounded-xl border border-outline-variant bg-surface-container-low px-4 py-3 min-h-[48px]" type="date" autocomplete="off" />
<span asp-validation-for="EndDate" class="text-error text-sm"></span>
</div>
<div>
<label asp-for="Guests" class="font-label-sm text-label-sm text-on-surface block mb-1"></label>
<input asp-for="Guests"
       class="w-full rounded-xl border border-outline-variant bg-surface-container-low px-4 py-3 min-h-[48px]"
       type="number"
       min="@(Model.MinGuests ?? 1)"
       max="@(Model.MaxGuests ?? 20)"
       data-min-guests="@(Model.MinGuests?.ToString() ?? "")"
       data-max-guests="@(Model.MaxGuests?.ToString() ?? "")"
       data-kind="@(Model.BookingKind ?? "")"
       autocomplete="off" />
<span asp-validation-for="Guests" class="text-error text-sm"></span>
<p class="text-error text-sm mt-1 hidden" data-capacity-inline-message></p>
</div>
<div>
<label asp-for="Notes" class="font-label-sm text-label-sm text-on-surface block mb-1"></label>
<textarea asp-for="Notes" rows="4" class="w-full rounded-xl border border-outline-variant bg-surface-container-low px-4 py-3 font-body-md" spellcheck="false" autocomplete="off"></textarea>
<span asp-validation-for="Notes" class="text-error text-sm"></span>
</div>

<button type="submit" class="w-full bg-primary text-on-primary font-button py-3 rounded-[16px] hover:opacity-90 transition-opacity disabled:opacity-50 disabled:cursor-not-allowed" data-booking-submit>Send request</button>
</form>
<div class="mt-8 font-body-md text-body-md text-on-surface-variant">
<a asp-controller="Home" asp-action="Index" class="text-primary hover:underline">← Back to home</a>
</div>
</section>
</main>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
}
