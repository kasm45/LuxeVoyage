@model LuxeVoyage.Mvc.Models.ViewModels.PaymentCheckoutViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.NavSection = "Book";
    ViewData["Title"] = "Checkout";
}
<main class="pt-[104px] pb-20 px-gutter md:px-xl max-w-[920px] mx-auto min-h-[60vh]">
    <div class="rounded-2xl border border-amber-200 bg-amber-50 dark:bg-amber-950/40 px-5 py-4 mb-8 flex gap-3 items-start shadow-sm">
        <span class="material-symbols-outlined text-amber-800 dark:text-amber-200 shrink-0 mt-0.5">privacy_tip</span>
        <div>
            <p class="font-semibold text-amber-950 dark:text-amber-100 text-sm">Demo payment only — do not enter real card details.</p>
            <p class="mt-1 text-sm text-amber-900/90 dark:text-amber-100/90">
                Success: <span class="font-mono">4242 4242 4242 4242</span> · Decline: <span class="font-mono">4000 0000 0000 0002</span>
            </p>
        </div>
    </div>

    <header class="mb-10">
        <p class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-[0.14em] mb-2">Secure checkout</p>
        <h1 class="font-h1 text-h1 text-[#0f172a] dark:text-[#faf8f5]">Complete your trip deposit</h1>
        <p class="mt-2 font-body-md text-body-md text-on-surface-variant max-w-xl">
            Review your request and submit a simulated payment for this portfolio demo. Checkout is available because your concierge approved this request. Card numbers are not stored—only brand and last four digits are saved.
        </p>
    </header>

    @if (!string.IsNullOrWhiteSpace((string?)TempData["Message"]))
    {
        <div class="mb-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm text-emerald-900">
            @TempData["Message"]
        </div>
    }
    @if (!string.IsNullOrWhiteSpace((string?)TempData["Error"]))
    {
        <div class="mb-6 rounded-2xl border border-red-200 bg-red-50 px-5 py-4 text-sm text-red-900">
            @TempData["Error"]
        </div>
    }

    <div class="rounded-[22px] border border-[#e8dfd6] bg-white dark:bg-slate-900/60 shadow-[0_12px_32px_-8px_rgba(15,23,42,0.1)] overflow-hidden mb-8">
        <div class="px-6 py-5 border-b border-[#f1e9e2] bg-[#fdfbf7] dark:bg-slate-900/80">
            <p class="font-label-caps text-label-caps text-[#9A6442] uppercase tracking-wider mb-1">@Model.KindLabel</p>
            <h2 class="font-h3 text-h3 text-[#0f172a] dark:text-[#faf8f5]">@Model.TripTitle</h2>
        </div>
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 px-6 py-6 font-body-md text-sm">
            <div><dt class="text-on-surface-variant/80">Dates</dt><dd class="text-on-surface font-medium">@Model.StartDate.ToString("MMM d, yyyy") – @Model.EndDate.ToString("MMM d, yyyy")</dd></div>
            <div><dt class="text-on-surface-variant/80">Guests</dt><dd class="text-on-surface font-medium">@Model.Guests</dd></div>
            <div class="sm:col-span-2">
                <dt class="text-on-surface-variant/80">Amount due</dt>
                <dd class="mt-1">
                    @if (Model.CanPay && Model.AmountDue > 0)
                    {
                        <span class="inline-flex items-center rounded-full bg-[#fdf6ef] border border-[#e7ddd4] px-4 py-2 font-semibold text-[#0f172a]">
                            @Model.Currency $@Model.AmountDue.ToString("0.00") — @Model.AmountSummary
                        </span>
                    }
                    else
                    {
                        <span class="inline-flex items-center rounded-full bg-slate-100 dark:bg-slate-800 px-4 py-2 font-semibold text-slate-700 dark:text-slate-200">Custom quote</span>
                    }
                </dd>
            </div>
        </dl>
    </div>

    @if (!Model.CanPay || Model.AmountDue <= 0)
    {
        <div class="rounded-[22px] border border-[#e8dfd6] bg-[#fdfbf7] dark:bg-slate-900/40 px-6 py-8 text-center">
            <span class="material-symbols-outlined text-4xl text-[#9A6442]/70 mb-3">hourglass_empty</span>
            <p class="font-h3 text-h3 text-[#0f172a] dark:text-[#faf8f5] mb-2">Awaiting concierge quote</p>
            <p class="font-body-md text-on-surface-variant max-w-md mx-auto">
                Your concierge will confirm the final quote before payment. You will see an estimated total here once pricing is available from the listing.
            </p>
            <a asp-controller="Cart" asp-action="Index" class="inline-flex mt-6 items-center justify-center rounded-full px-6 py-3 font-label-sm text-label-sm bg-[#1e3a5f] text-[#faf8f5] shadow-md hover:brightness-110 transition-all">Back to basket</a>
        </div>
    }
    else
    {
        <form asp-controller="Payments" asp-action="Checkout" asp-route-bookingId="@Model.BookingId" method="post" class="space-y-8">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="rounded-2xl border border-red-200 bg-red-50 px-5 py-4 text-sm text-red-900 mb-2"></div>

            <section class="rounded-[22px] border border-[#e8dfd6] bg-white dark:bg-slate-900/60 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-[#f1e9e2] bg-[#fdfbf7]/80">
                    <h3 class="font-h3 text-[18px] text-[#0f172a] dark:text-[#faf8f5]">Billing details</h3>
                </div>
                <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="md:col-span-2">
                        <label asp-for="BillingName" class="block text-xs font-semibold text-on-surface-variant mb-1">Full name</label>
                        <input asp-for="BillingName" class="w-full rounded-xl border border-[#e7ddd4] bg-white px-4 py-3 text-sm focus:ring-2 focus:ring-[#9A6442]/40 focus:border-[#9A6442] outline-none" autocomplete="name" />
                        <span asp-validation-for="BillingName" class="text-xs text-red-600 mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="BillingEmail" class="block text-xs font-semibold text-on-surface-variant mb-1">Email</label>
                        <input asp-for="BillingEmail" type="email" class="w-full rounded-xl border border-[#e7ddd4] bg-white px-4 py-3 text-sm focus:ring-2 focus:ring-[#9A6442]/40 focus:border-[#9A6442] outline-none" autocomplete="email" />
                        <span asp-validation-for="BillingEmail" class="text-xs text-red-600 mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="BillingPhone" class="block text-xs font-semibold text-on-surface-variant mb-1">Phone</label>
                        <input asp-for="BillingPhone" class="w-full rounded-xl border border-[#e7ddd4] bg-white px-4 py-3 text-sm focus:ring-2 focus:ring-[#9A6442]/40 focus:border-[#9A6442] outline-none" autocomplete="tel" />
                    </div>
                    <div>
                        <label asp-for="BillingCountry" class="block text-xs font-semibold text-on-surface-variant mb-1">Country</label>
                        <input asp-for="BillingCountry" class="w-full rounded-xl border border-[#e7ddd4] bg-white px-4 py-3 text-sm focus:ring-2 focus:ring-[#9A6442]/40 focus:border-[#9A6442] outline-none" autocomplete="country-name" />
                    </div>
                    <div>
                        <label asp-for="BillingCity" class="block text-xs font-semibold text-on-surface-variant mb-1">City</label>
                        <input asp-for="BillingCity" class="w-full rounded-xl border border-[#e7ddd4] bg-white px-4 py-3 text-sm focus:ring-2 focus:ring-[#9A6442]/40 focus:border-[#9A6442] outline-none" autocomplete="address-level2" />
                    </div>
                    <div class="md:col-span-2">
                        <label asp-for="BillingAddressLine" class="block text-xs font-semibold text-on-surface-variant mb-1">Address</label>
                        <input asp-for="BillingAddressLine" class="w-full rounded-xl border border-[#e7ddd4] bg-white px-4 py-3 text-sm focus:ring-2 focus:ring-[#9A6442]/40 focus:border-[#9A6442] outline-none" autocomplete="street-address" />
                    </div>
                </div>
            </section>

            <section class="rounded-[22px] border border-[#e8dfd6] bg-white dark:bg-slate-900/60 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-[#f1e9e2] bg-[#fdfbf7]/80">
                    <h3 class="font-h3 text-[18px] text-[#0f172a] dark:text-[#faf8f5]">Demo card</h3>
                    <p class="text-xs text-on-surface-variant mt-1">CVV is validated but never stored.</p>
                </div>
                <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="md:col-span-2">
                        <label asp-for="CardholderName" class="block text-xs font-semibold text-on-surface-variant mb-1">Cardholder name</label>
                        <input asp-for="CardholderName" class="w-full rounded-xl border border-[#e7ddd4] bg-white px-4 py-3 text-sm focus:ring-2 focus:ring-[#9A6442]/40 focus:border-[#9A6442] outline-none" autocomplete="off" />
                        <span asp-validation-for="CardholderName" class="text-xs text-red-600 mt-1 block"></span>
                    </div>
                    <div class="md:col-span-2">
                        <label asp-for="CardNumber" class="block text-xs font-semibold text-on-surface-variant mb-1">Card number</label>
                        <input asp-for="CardNumber" class="w-full rounded-xl border border-[#e7ddd4] bg-white px-4 py-3 text-sm font-mono tracking-wide focus:ring-2 focus:ring-[#9A6442]/40 focus:border-[#9A6442] outline-none" placeholder="4242 4242 4242 4242" autocomplete="off" />
                        <span asp-validation-for="CardNumber" class="text-xs text-red-600 mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="ExpiryMonth" class="block text-xs font-semibold text-on-surface-variant mb-1">Expiry month</label>
                        <input asp-for="ExpiryMonth" id="checkout-expiry-month" data-digits-only data-max-length="2" pattern="[0-9]*" class="w-full rounded-xl border border-[#e7ddd4] bg-white px-4 py-3 text-sm focus:ring-2 focus:ring-[#9A6442]/40 focus:border-[#9A6442] outline-none" placeholder="MM" autocomplete="off" inputmode="numeric" maxlength="2" />
                        <p class="mt-1 text-xs text-on-surface-variant/90">01–12</p>
                        <span asp-validation-for="ExpiryMonth" class="text-xs text-red-600 mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="ExpiryYear" class="block text-xs font-semibold text-on-surface-variant mb-1">Expiry year</label>
                        <input asp-for="ExpiryYear" id="checkout-expiry-year" data-digits-only data-max-length="4" pattern="[0-9]*" class="w-full rounded-xl border border-[#e7ddd4] bg-white px-4 py-3 text-sm focus:ring-2 focus:ring-[#9A6442]/40 focus:border-[#9A6442] outline-none" placeholder="YY or YYYY" autocomplete="off" inputmode="numeric" maxlength="4" />
                        <p class="mt-1 text-xs text-on-surface-variant/90">Must not be in the past</p>
                        <span asp-validation-for="ExpiryYear" class="text-xs text-red-600 mt-1 block"></span>
                    </div>
                    <div class="md:col-span-2">
                        <label asp-for="Cvv" class="block text-xs font-semibold text-on-surface-variant mb-1">CVV</label>
                        <input asp-for="Cvv" id="checkout-cvv" type="password" data-digits-only data-max-length="4" pattern="[0-9]*" class="w-full rounded-xl border border-[#e7ddd4] bg-white px-4 py-3 text-sm focus:ring-2 focus:ring-[#9A6442]/40 focus:border-[#9A6442] outline-none max-w-[180px]" placeholder="123" autocomplete="off" inputmode="numeric" maxlength="4" />
                        <p class="mt-1 text-xs text-on-surface-variant/90">3 or 4 digits only — never stored</p>
                        <span asp-validation-for="Cvv" class="text-xs text-red-600 mt-1 block"></span>
                    </div>
                </div>
            </section>

            <div class="flex flex-wrap items-center gap-4 pt-2">
                <button type="submit" class="inline-flex items-center justify-center gap-2 rounded-full px-8 py-3.5 font-label-sm text-label-sm bg-gradient-to-r from-[#9A6442] to-[#7A4B31] text-white shadow-lg hover:brightness-110 transition-all">
                    Pay &amp; Confirm
                </button>
                <a asp-controller="Cart" asp-action="Index" class="text-sm font-semibold text-[#1e3a5f] hover:underline underline-offset-4">Cancel</a>
            </div>
        </form>
    }
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            function attachDigitsOnly(el) {
                if (!el || !el.hasAttribute('data-digits-only')) return;
                var max = parseInt(el.getAttribute('data-max-length') || '999', 10);
                el.addEventListener('input', function () {
                    var v = el.value.replace(/\D/g, '');
                    if (v.length > max) v = v.slice(0, max);
                    el.value = v;
                });
            }
            document.querySelectorAll('[data-digits-only]').forEach(attachDigitsOnly);
        })();
    </script>
}
