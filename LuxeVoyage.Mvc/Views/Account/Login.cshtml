@model LuxeVoyage.Mvc.Models.ViewModels.LoginViewModel
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.NavSection = "Login";
    ViewData["Title"] = "LuxeVoyage - Login";
}
<div class="bg-background text-on-background min-h-screen flex antialiased">
<div class="hidden lg:flex lg:w-1/2 relative bg-surface-container-high overflow-hidden">
<img class="absolute inset-0 w-full h-full object-cover" alt="" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBrgLu-21lmYArw92ihCqaLV_BUSZhTuHrFQz_k9JfqmVOc5WPwjFnH4HP9KzjnsI-0KQtCGm2FISV0L68MQCIKn7vgJAYvaqS144hrIUe8uADn0udsZwM_9iIi_YecMN7uHPd8EPlJfm0MxDAG4veCejxHmCs-d7l0tJ-dCRYBdZsgqqXpWwkkcmgX2eeQG9fcQBAV7yFWZf4iD4zsmqgL6XX56a-Rcx8DSvbRXgpZRncz_cUHD5o3_q94FUuXzen3uAyzkN9Oxik"/>
<div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-primary/45 to-transparent flex flex-col justify-end px-10 pb-14 pt-24 text-on-primary">
<h2 class="font-h2 text-h2 mb-sm">Discover your next horizon.</h2>
<p class="font-body-lg text-body-lg opacity-90 max-w-md">Access your itinerary, manage bookings, and explore curated destinations all in one place.</p>
</div>
</div>
<div class="w-full lg:w-1/2 flex items-center justify-center px-4 py-10 sm:px-8 lg:px-10 bg-surface-lowest">
<div class="w-full max-w-[470px] bg-surface rounded-2xl p-6 sm:p-8 border border-outline-variant shadow-[0_18px_45px_rgba(15,23,42,0.08)]">
<div class="mb-6 text-center">
<div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-primary-fixed mb-sm">
<span class="material-symbols-outlined text-primary text-[28px]">flight_takeoff</span>
</div>
<h1 class="font-h1 text-h3 text-primary tracking-tighter">LuxeVoyage</h1>
<div id="lv-login-sub-traveler" class="@(Model.AdminLogin ? "hidden" : "") mt-2 space-y-1">
<p class="font-body-md text-body-md text-on-surface-variant">Welcome back. Please enter your details.</p>
</div>
<div id="lv-login-sub-admin" class="@(!Model.AdminLogin ? "hidden" : "") mt-2 space-y-1">
<p class="font-body-md text-body-md text-on-surface font-semibold">Staff sign in</p>
<p class="text-sm leading-snug text-on-surface-variant">Use your admin or personnel account to manage reservation requests.</p>
</div>
</div>
<div class="lv-login-tabs mb-4" role="tablist" aria-label="Sign-in mode">
<button type="button" id="lv-tab-traveler" class="lv-login-tab @(Model.AdminLogin ? "" : "is-active")" data-lv-mode="traveler" aria-selected="@(!Model.AdminLogin ? "true" : "false")">Traveler</button>
<button type="button" id="lv-tab-admin" class="lv-login-tab @(Model.AdminLogin ? "is-active" : "")" data-lv-mode="admin" aria-selected="@(Model.AdminLogin ? "true" : "false")">Staff</button>
</div>

<div asp-validation-summary="ModelOnly" class="text-error text-sm mb-3"></div>

<form asp-controller="Account" asp-action="Login" method="post" class="space-y-4" id="lv-login-form">
@Html.AntiForgeryToken()
<input type="hidden" asp-for="ReturnUrl" />
<input type="hidden" asp-for="AdminLogin" id="lv-admin-login-hidden" />
<div class="flex flex-col gap-1.5">
<label asp-for="Email" class="font-label-sm text-label-sm text-on-surface">Email</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline text-[20px]">mail</span>
<input asp-for="Email" class="w-full h-[50px] pl-12 pr-4 bg-surface-container-low border border-outline rounded-xl text-on-surface font-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors" autocomplete="username" />
</div>
<span asp-validation-for="Email" class="text-error text-sm"></span>
</div>
<div class="flex flex-col gap-1.5">
<label asp-for="Password" class="font-label-sm text-label-sm text-on-surface">Password</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline text-[20px]">lock</span>
<input asp-for="Password" class="w-full h-[50px] pl-12 pr-4 bg-surface-container-low border border-outline rounded-xl text-on-surface font-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors" autocomplete="current-password" />
</div>
<span asp-validation-for="Password" class="text-error text-sm"></span>
</div>
<div class="flex items-center gap-2 pt-1">
<input asp-for="RememberMe" class="rounded border-outline" />
<label asp-for="RememberMe" class="font-body-md text-body-md text-on-surface-variant">Remember me</label>
</div>
<div class="pt-1">
<button type="submit" class="w-full h-[50px] bg-primary text-on-primary font-label-sm text-label-sm rounded-xl flex items-center justify-center gap-base hover:opacity-90 active:scale-[0.98] transition-all">
                        Sign In
                        <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
</button>
</div>
</form>

<div class="mt-6 mb-4 flex items-center">
<div class="flex-grow border-t border-outline-variant"></div>
<span class="px-sm font-label-sm text-label-sm text-outline">OR CONTINUE WITH</span>
<div class="flex-grow border-t border-outline-variant"></div>
</div>
<div class="flex flex-col gap-2.5 pointer-events-none select-none">
<button type="button" class="lv-login-demo-provider" disabled>
    <span>Google</span>
    <span class="lv-login-demo-chip">Demo only</span>
</button>
<button type="button" class="lv-login-demo-provider" disabled>
    <span>Apple</span>
    <span class="lv-login-demo-chip">Demo only</span>
</button>
</div>
<p class="mt-6 text-center font-body-md text-body-md text-on-surface-variant">
                Don't have an account? <a asp-controller="Account" asp-action="Register" class="font-label-sm text-label-sm text-primary hover:text-secondary-container transition-colors">Sign up</a>
</p>
@if (Env.IsDevelopment())
{
<section class="mt-5 rounded-xl border border-slate-200 bg-slate-50/85 px-4 py-3 text-sm text-slate-600">
<p class="text-[11px] uppercase tracking-[0.08em] font-semibold text-slate-500 mb-2">Demo credentials</p>
<div class="space-y-2">
<div class="flex flex-wrap items-center gap-2">
<span class="lv-login-cred-badge">Traveler</span>
<span class="break-all">traveler@demo.com / Traveler123!</span>
</div>
<div class="flex flex-wrap items-center gap-2">
<span class="lv-login-cred-badge">Admin</span>
<span class="break-all">admin@luxevoyage.com / Admin123!</span>
</div>
</div>
</section>
}
</div>
</div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
(function () {
  var hidden = document.getElementById('lv-admin-login-hidden');
  var tabTraveler = document.getElementById('lv-tab-traveler');
  var tabAdmin = document.getElementById('lv-tab-admin');
  var subTraveler = document.getElementById('lv-login-sub-traveler');
  var subAdmin = document.getElementById('lv-login-sub-admin');
  if (!hidden || !tabTraveler || !tabAdmin) return;

  function setMode(admin) {
    hidden.value = admin ? 'true' : 'false';
    tabTraveler.setAttribute('aria-selected', admin ? 'false' : 'true');
    tabAdmin.setAttribute('aria-selected', admin ? 'true' : 'false');
    tabTraveler.classList.toggle('is-active', !admin);
    tabAdmin.classList.toggle('is-active', admin);
    if (subTraveler) subTraveler.classList.toggle('hidden', admin);
    if (subAdmin) subAdmin.classList.toggle('hidden', !admin);
  }

  tabTraveler.addEventListener('click', function () { setMode(false); });
  tabAdmin.addEventListener('click', function () { setMode(true); });
})();
</script>
}
