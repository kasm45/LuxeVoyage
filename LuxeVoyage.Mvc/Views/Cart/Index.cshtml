@model LuxeVoyage.Mvc.Models.ViewModels.CartIndexViewModel

@{

    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewBag.NavSection = "Cart";

    ViewData["Title"] = "Your Travel Basket";

    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

    var hasCart = Model.Rows.Count > 0;

    var hasWaiting = Model.WaitingForReview.Count > 0;

    var hasReady = Model.ReadyForPayment.Count > 0;

    var hasPaidStrip = Model.RecentlyPaid.Count > 0;

    var hasReservationStrip = hasWaiting || hasReady || hasPaidStrip;

}



<main class="pt-[104px] pb-20 px-gutter md:px-xl max-w-[960px] mx-auto min-h-[60vh]">

    <header class="mb-10">

        <p class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-[0.14em] mb-2">Travel basket</p>

        <h1 class="font-h1 text-h1 text-[#0f172a] dark:text-[#faf8f5]">Your Travel Basket</h1>

        <p class="mt-2 font-body-md text-body-md text-on-surface-variant max-w-xl">Requests awaiting review appear first; once approved you can complete demo payment here. Paid trips stay visible briefly — full details live under My trips.</p>

    </header>



    @if (!string.IsNullOrWhiteSpace((string?)TempData["Message"]))

    {

        <div class="mb-6 rounded-2xl border border-primary/25 bg-[#faf8f5] dark:bg-slate-800/80 px-5 py-4 text-sm text-on-surface shadow-sm">

            @TempData["Message"]

        </div>

    }

    @if (!string.IsNullOrWhiteSpace((string?)TempData["Error"]))

    {

        <div class="mb-6 rounded-2xl border border-red-200 bg-red-50 px-5 py-4 text-sm text-red-900">

            @TempData["Error"]

        </div>

    }



    @if (!hasCart && !hasReservationStrip)

    {

        <div class="rounded-[22px] border border-[#e7ddd4] bg-gradient-to-br from-[#fdfbf7] via-white to-[#f4ebe3] shadow-[0_20px_48px_-12px_rgba(15,23,42,0.12)] px-8 py-14 text-center">

            <span class="material-symbols-outlined text-5xl text-[#1e3a5f] mb-4 opacity-90">shopping_bag</span>

            <h2 class="font-h2 text-h2 text-[#0f172a] mb-2">Your basket is ready for your next journey.</h2>

            <p class="font-body-md text-on-surface-variant max-w-md mx-auto mb-8">Save destinations, experiences, tours, or stays here — then request availability when you are ready.</p>

            <div class="flex flex-col sm:flex-row flex-wrap justify-center gap-3">

                <a asp-controller="Destinations" asp-action="Index" class="inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 font-label-sm text-label-sm bg-[#1e3a5f] text-[#faf8f5] shadow-md hover:brightness-110 transition-all">Explore destinations</a>

                <a asp-controller="Experiences" asp-action="Index" class="inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 font-label-sm text-label-sm border border-[#1e3a5f]/25 text-[#1e3a5f] bg-white/80 hover:bg-white transition-all">Browse experiences</a>

                <a asp-controller="Tours" asp-action="Index" class="inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 font-label-sm text-label-sm border border-[#1e3a5f]/25 text-[#1e3a5f] bg-white/80 hover:bg-white transition-all">Browse tours</a>

                <a asp-controller="Hotels" asp-action="Index" class="inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 font-label-sm text-label-sm border border-[#1e3a5f]/25 text-[#1e3a5f] bg-white/80 hover:bg-white transition-all">Find stays</a>

            </div>

        </div>

    }

    else

    {

        @if (hasReservationStrip)

        {

            <div class="space-y-12 mb-12">

                @if (hasWaiting)

                {

                    <section>

                        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-6">

                            <div>

                                <h2 class="font-h3 text-h3 text-[#0f172a] dark:text-[#faf8f5]">Waiting for concierge review</h2>

                                <p class="font-body-md text-body-md text-on-surface-variant mt-1 max-w-xl">Our concierge team is reviewing availability. Payment opens after approval.</p>

                            </div>

                            <a asp-controller="Account" asp-action="Reservations" class="inline-flex items-center gap-2 text-sm font-semibold text-[#9A6442] hover:underline underline-offset-4">My trips</a>

                        </div>

                        <ul class="space-y-5">

                            @foreach (var p in Model.WaitingForReview)

                            {

                                <li class="rounded-[20px] border border-[#e8dfd6] bg-white dark:bg-slate-900/60 shadow-[0_12px_32px_-8px_rgba(15,23,42,0.1)] overflow-hidden flex flex-col md:flex-row">

                                    <div class="relative md:w-[220px] shrink-0 h-48 md:h-auto bg-surface-container-low">

                                        @if (!string.IsNullOrEmpty(p.ImageUrl))

                                        {

                                            <img src="@p.ImageUrl" alt="" class="absolute inset-0 w-full h-full object-cover" onerror="this.onerror=null;this.src='/images/placeholders/lv-placeholder.svg';" />

                                        }

                                        else

                                        {

                                            <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-[#9A6442]/15 to-transparent">

                                                <span class="material-symbols-outlined text-4xl text-[#9A6442]/40">travel_explore</span>

                                            </div>

                                        }

                                    </div>

                                    <div class="flex flex-col flex-grow p-6 md:p-7 gap-4">

                                        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">

                                            <div class="min-w-0">

                                                <div class="flex flex-wrap items-center gap-2 mb-2">

                                                    <span class="inline-flex items-center rounded-full border border-[#e7ddd4] bg-[#fdf6ef] px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-[#7A4B31]">@p.KindBadge</span>

                                                    <span class="inline-flex items-center rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-[11px] font-semibold text-amber-900">@p.StatusHeadline</span>

                                                </div>

                                                <h3 class="font-h3 text-h3 text-[#0f172a] dark:text-[#faf8f5] leading-snug truncate">@p.Title</h3>

                                                <p class="mt-2 text-sm text-on-surface-variant">@p.PaymentHint</p>

                                                <dl class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2 font-body-md text-sm text-on-surface-variant">

                                                    <div class="flex gap-2"><dt class="text-on-surface-variant/80 shrink-0">Dates</dt><dd class="text-on-surface">@p.StartDate.ToString("MMM d, yyyy") – @p.EndDate.ToString("MMM d, yyyy")</dd></div>

                                                    <div class="flex gap-2"><dt class="text-on-surface-variant/80 shrink-0">Guests</dt><dd class="text-on-surface">@p.Guests</dd></div>

                                                </dl>

                                            </div>

                                            <span class="shrink-0 inline-flex items-center rounded-full bg-[#fdf6ef] border border-[#e7ddd4] px-4 py-2 font-semibold text-[#0f172a] text-sm text-center max-w-[min(100%,220px)] leading-snug">@p.PriceDisplayLine</span>

                                        </div>

                                        <div class="flex flex-wrap items-center gap-3 pt-2 border-t border-[#f1e9e2]">

                                            <a href="@p.ConfirmationUrl" class="inline-flex items-center justify-center gap-2 rounded-full px-5 py-2.5 font-label-sm text-label-sm bg-gradient-to-r from-[#9A6442] to-[#7A4B31] text-white shadow-md hover:brightness-110 transition-all">View request</a>

                                            <a href="@p.DetailUrl" class="inline-flex items-center justify-center gap-1 rounded-full px-4 py-2 font-label-sm text-label-sm text-[#1e3a5f] border border-[#1e3a5f]/20 hover:bg-[#f8fafc] transition-colors">View listing</a>

                                            <form asp-controller="Account" asp-action="CancelReservation" asp-route-id="@p.BookingId" method="post" class="ml-auto" onsubmit="return confirm('Cancel this pending request?');">

                                                @Html.AntiForgeryToken()

                                                <button type="submit" class="inline-flex items-center gap-1 text-sm font-medium text-slate-400 hover:text-red-600 transition-colors">

                                                    <span class="material-symbols-outlined text-[18px]">cancel</span>

                                                    Cancel request

                                                </button>

                                            </form>

                                        </div>

                                    </div>

                                </li>

                            }

                        </ul>

                    </section>

                }



                @if (hasReady)

                {

                    <section>

                        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-6">

                            <div>

                                <h2 class="font-h3 text-h3 text-[#0f172a] dark:text-[#faf8f5]">Ready for payment</h2>

                                <p class="font-body-md text-body-md text-on-surface-variant mt-1 max-w-xl">Approved — payment available. Complete demo checkout to secure your trip.</p>

                            </div>

                        </div>

                        <ul class="space-y-5">

                            @foreach (var p in Model.ReadyForPayment)

                            {

                                <li class="rounded-[20px] border border-emerald-200/80 bg-emerald-50/40 dark:bg-slate-900/60 shadow-[0_12px_32px_-8px_rgba(15,23,42,0.1)] overflow-hidden flex flex-col md:flex-row">

                                    <div class="relative md:w-[220px] shrink-0 h-48 md:h-auto bg-surface-container-low">

                                        @if (!string.IsNullOrEmpty(p.ImageUrl))

                                        {

                                            <img src="@p.ImageUrl" alt="" class="absolute inset-0 w-full h-full object-cover" onerror="this.onerror=null;this.src='/images/placeholders/lv-placeholder.svg';" />

                                        }

                                        else

                                        {

                                            <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-emerald-100/50 to-transparent">

                                                <span class="material-symbols-outlined text-4xl text-emerald-700/35">payments</span>

                                            </div>

                                        }

                                    </div>

                                    <div class="flex flex-col flex-grow p-6 md:p-7 gap-4">

                                        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">

                                            <div class="min-w-0">

                                                <div class="flex flex-wrap items-center gap-2 mb-2">

                                                    <span class="inline-flex items-center rounded-full border border-[#e7ddd4] bg-white px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-[#7A4B31]">@p.KindBadge</span>

                                                    <span class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-[11px] font-semibold text-emerald-900">@p.StatusHeadline</span>

                                                </div>

                                                <h3 class="font-h3 text-h3 text-[#0f172a] dark:text-[#faf8f5] leading-snug truncate">@p.Title</h3>

                                                <p class="mt-2 text-sm text-on-surface-variant">@p.PaymentHint</p>

                                                <dl class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2 font-body-md text-sm text-on-surface-variant">

                                                    <div class="flex gap-2"><dt class="text-on-surface-variant/80 shrink-0">Dates</dt><dd class="text-on-surface">@p.StartDate.ToString("MMM d, yyyy") – @p.EndDate.ToString("MMM d, yyyy")</dd></div>

                                                    <div class="flex gap-2"><dt class="text-on-surface-variant/80 shrink-0">Guests</dt><dd class="text-on-surface">@p.Guests</dd></div>

                                                </dl>

                                            </div>

                                            <span class="shrink-0 inline-flex items-center rounded-full bg-white border border-emerald-200 px-4 py-2 font-semibold text-[#0f172a] text-sm text-center max-w-[min(100%,220px)] leading-snug">@p.PriceDisplayLine</span>

                                        </div>

                                        <div class="flex flex-wrap items-center gap-2">

                                            @if (p.ShowPayNow)

                                            {

                                                <a href="@p.CheckoutUrl" class="inline-flex items-center justify-center gap-2 rounded-full px-6 py-2.5 font-label-sm text-label-sm bg-[#1e3a5f] text-[#faf8f5] shadow-md hover:brightness-110 transition-all">Pay now</a>

                                            }

                                            else if (p.ShowAwaitingQuote)

                                            {

                                                <span class="inline-flex items-center rounded-full border border-amber-200 bg-amber-50 px-4 py-2 text-xs font-semibold text-amber-900">Awaiting concierge quote</span>

                                            }

                                        </div>

                                        <div class="flex flex-wrap items-center gap-3 pt-2 border-t border-emerald-200/60">

                                            <a href="@p.ConfirmationUrl" class="inline-flex items-center justify-center gap-2 rounded-full px-5 py-2.5 font-label-sm text-label-sm bg-gradient-to-r from-[#9A6442] to-[#7A4B31] text-white shadow-md hover:brightness-110 transition-all">View request</a>

                                            <a href="@p.DetailUrl" class="inline-flex items-center justify-center gap-1 rounded-full px-4 py-2 font-label-sm text-label-sm text-[#1e3a5f] border border-[#1e3a5f]/20 hover:bg-[#f8fafc] transition-colors">View listing</a>

                                            <form asp-controller="Account" asp-action="CancelReservation" asp-route-id="@p.BookingId" method="post" class="ml-auto" onsubmit="return confirm('Cancel this reservation?');">

                                                @Html.AntiForgeryToken()

                                                <button type="submit" class="inline-flex items-center gap-1 text-sm font-medium text-slate-400 hover:text-red-600 transition-colors">

                                                    <span class="material-symbols-outlined text-[18px]">cancel</span>

                                                    Cancel

                                                </button>

                                            </form>

                                        </div>

                                    </div>

                                </li>

                            }

                        </ul>

                    </section>

                }



                @if (hasPaidStrip)

                {

                    <section>

                        <div class="mb-6">

                            <h2 class="font-h3 text-h3 text-[#0f172a] dark:text-[#faf8f5]">Recently secured</h2>

                            <p class="font-body-md text-body-md text-on-surface-variant mt-1 max-w-xl">Payment received — your trip details now live under My trips.</p>

                        </div>

                        <ul class="space-y-4">

                            @foreach (var p in Model.RecentlyPaid)

                            {

                                <li class="rounded-[18px] border border-[#dfe8f3] bg-[#f8fafc] dark:bg-slate-900/40 px-5 py-4 flex flex-col sm:flex-row sm:items-center gap-4">

                                    <div class="min-w-0 flex-grow">

                                        <div class="flex flex-wrap items-center gap-2 mb-1">

                                            <span class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-2.5 py-0.5 text-[11px] font-bold text-emerald-900">Payment received</span>

                                            <span class="text-xs text-on-surface-variant">#@p.BookingId</span>

                                        </div>

                                        <p class="font-semibold text-[#0f172a] dark:text-[#faf8f5] truncate">@p.Title</p>

                                        <p class="text-sm text-on-surface-variant mt-1">@p.PaymentHint Paid $@p.PaidAmountUsd?.ToString("0.00") USD.</p>

                                    </div>

                                    <div class="flex flex-wrap gap-2 shrink-0">

                                        <a href="@p.MyTripsUrl" class="inline-flex items-center justify-center rounded-full px-5 py-2 text-sm font-semibold bg-[#1e3a5f] text-[#faf8f5] hover:brightness-110 transition-all">View in My trips</a>

                                        <a href="@p.PaymentReceiptUrl" class="inline-flex items-center justify-center rounded-full px-4 py-2 text-sm font-semibold border border-[#1e3a5f]/25 text-[#1e3a5f] hover:bg-white transition-colors">Receipt</a>

                                    </div>

                                </li>

                            }

                        </ul>

                    </section>

                }

            </div>

        }



        @if (hasCart)

        {

            <section>

                <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-6">

                    <div>

                        <h2 class="font-h3 text-h3 text-[#0f172a] dark:text-[#faf8f5]">Saved for later</h2>

                        <p class="font-body-md text-body-md text-on-surface-variant mt-1 max-w-xl">Not ready to request yet? Keep these trips here until you choose dates and guests.</p>

                    </div>

                </div>

                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">

                    <p class="font-body-md text-on-surface-variant">@Model.Rows.Count @(Model.Rows.Count == 1 ? "saved trip" : "saved trips")</p>

                    <form asp-controller="Cart" asp-action="Clear" method="post" class="inline">

                        @Html.AntiForgeryToken()

                        <button type="submit" class="text-sm font-semibold text-[#94a3b8] hover:text-red-700 underline-offset-4 hover:underline transition-colors">Clear saved items</button>

                    </form>

                </div>



                <ul class="space-y-5">

                    @foreach (var row in Model.Rows)

                    {

                        <li class="rounded-[20px] border border-[#e8dfd6] bg-white dark:bg-slate-900/60 shadow-[0_12px_32px_-8px_rgba(15,23,42,0.1)] overflow-hidden flex flex-col md:flex-row">

                            <div class="relative md:w-[220px] shrink-0 h-48 md:h-auto bg-surface-container-low">

                                @if (!string.IsNullOrEmpty(row.ImageUrl))

                                {

                                    <img src="@row.ImageUrl" alt="" class="absolute inset-0 w-full h-full object-cover" onerror="this.onerror=null;this.src='/images/placeholders/lv-placeholder.svg';" />

                                }

                                else

                                {

                                    <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-[#1e3a5f]/10 to-transparent">

                                        <span class="material-symbols-outlined text-4xl text-[#1e3a5f]/35">image</span>

                                    </div>

                                }

                            </div>

                            <div class="flex flex-col flex-grow p-6 md:p-7 gap-4">

                                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">

                                    <div>

                                        <p class="font-label-caps text-label-caps text-[#9A6442] uppercase tracking-wider mb-1">@row.TypeLabel</p>

                                        <h2 class="font-h3 text-h3 text-[#0f172a] dark:text-[#faf8f5] leading-snug">

                                            <a href="@row.DetailUrl" class="hover:text-[#9A6442] transition-colors">@row.Title</a>

                                        </h2>

                                        <p class="mt-2 font-body-md text-body-md text-on-surface-variant flex items-start gap-1.5">

                                            <span class="material-symbols-outlined text-[18px] shrink-0 mt-0.5">location_on</span>

                                            @row.LocationLine

                                        </p>

                                    </div>

                                    <span class="shrink-0 inline-flex items-center rounded-full bg-[#fdf6ef] border border-[#e7ddd4] px-4 py-2 font-semibold text-[#0f172a] text-sm text-center max-w-[min(100%,220px)] leading-snug">@row.PriceDisplayLine</span>

                                </div>

                                <div class="flex flex-wrap items-center gap-3 pt-2 border-t border-[#f1e9e2]">

                                    <a href="@row.BookingUrl" class="inline-flex items-center justify-center gap-2 rounded-full px-5 py-2.5 font-label-sm text-label-sm bg-gradient-to-r from-[#9A6442] to-[#7A4B31] text-white shadow-md hover:brightness-110 transition-all">Request booking</a>

                                    <a href="@row.DetailUrl" class="inline-flex items-center justify-center gap-1 rounded-full px-4 py-2 font-label-sm text-label-sm text-[#1e3a5f] border border-[#1e3a5f]/20 hover:bg-[#f8fafc] transition-colors">View details</a>

                                    <form asp-controller="Cart" asp-action="Remove" asp-route-id="@row.CartItemId" method="post" class="ml-auto">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="returnUrl" value="@returnUrl" />

                                        <button type="submit" class="inline-flex items-center gap-1 text-sm font-medium text-slate-400 hover:text-red-600 transition-colors">

                                            <span class="material-symbols-outlined text-[18px]">delete</span>

                                            Remove

                                        </button>

                                    </form>

                                </div>

                            </div>

                        </li>

                    }

                </ul>

            </section>

        }

    }

</main>

